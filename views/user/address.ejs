            <div class="col-md-9 p-5">
    <h2 class="text-center mb-5 fw-light" style="font-family: 'Cinzel', serif; letter-spacing: 4px;">My Addresses</h2>

    <div class="row">
        <div class="col-md-6 col-lg-4 mb-4">
            <a href="/add-address" style="text-decoration: none;">
                <div class="address-card add-address-dashed h-100">
                    <i class="bi bi-plus-circle" style="font-size: 2.5rem;"></i>
                    <p class="mt-3 fw-bold text-uppercase" style="letter-spacing: 1px;">Add New Address</p>
                </div>
            </a>
        </div>

        <%if(userAddress && userAddress.address.length > 0 ){%>
            <% userAddress.address.forEach((address)=>{%>
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="address-card h-100">
                        <div class="name-header"><%=address.name %></div>
                        
                        <p><strong>Landmark:</strong> <%=address.landmark %></p>
                        <p><strong>State:</strong> <%=address.state %> (<%=address.pincode %>)</p>
                        <p><strong>Address:</strong> <%=address.fullAddress %></p>
                        <p><strong>Phone:</strong> <%=address.phone %></p>
                        
                        <div class="address-actions mt-4 d-flex gap-2">
                            <a href="/edit-address?id=<%=address._id%>" class="btn btn-edit">Edit</a>
                            <a href="#" class="btn btn-delete delete-btn" data-id='<%=address._id%>'>Delete</a>
                        </div>
                    </div>
                </div>
            <%})%>
        <%}else{%>
            <%}%>
    </div>
</div>

        </div>

