<%-include("../../views/partials/user/header")%>
    <link rel="stylesheet" href="/css/view-order.css" />

    <div class="container my-5">
        <!-- Order Header -->
        <div class="card shadow-lg p-4 mb-4">
            <h4 class="fw-bold text-center mb-4 text-secondary">
                Order #<%= order.orderId %>
            </h4>
            <%
            const statuses = ['Pending', 'Shipped', 'Out for Delivery', 'Delivered'];
            let displayStatus = order.status;
            const returnStatuses = ['Return Requested','Return Approved','Return Rejected'];

            if (returnStatuses.includes(order.status)) {
                displayStatus = 'Delivered';
            }

            let activeIndex = statuses.indexOf(displayStatus);

            if (activeIndex === -1) {
                activeIndex = statuses.length - 1;
            }
            %>

            <div class="d-flex justify-content-around mb-3">
                <% statuses.forEach(function(status, idx) { %>
                    <div class="text-center">
                        <div class="circle <%= idx <= activeIndex ? 'active' : '' %>"></div>
                        <p class="mt-2">
                            <%= status.toUpperCase() %>
                        </p>
                    </div>
                    <% }) %>
            </div>

            <!-- Order Dates -->
            <div class="bg-light p-3 rounded">
                <p>
                    <strong>Order Placed On:</strong>
                    <%= order.invoiceDate.toLocaleDateString('en-GB',{day:'numeric',month:'short',year:'numeric'}) %>
                </p>
                <p>
                    <strong>Delivered On:</strong>
                    <%= order.deliveredDate ?
                        order.deliveredDate.toLocaleDateString('en-GB',{day:'numeric',month:'short',year:'numeric'})
                        : 'N/A' %>
                </p>
            </div>
            <% if(order.status && order.status.toLowerCase().trim()==='delivered' ){ %>
                <div class="text-end mt-3">
                    <button class="btn btn-warning btn-sm" data-bs-toggle="modal" data-bs-target="#returnOrderModal"
                        data-order="<%= order.orderId %>">
                        Return Order
                    </button>
                </div>
                <% } %>
        </div>
        <!-- Product Details -->
        <div class="card shadow-sm mb-4">
            <div class="card-header fw-bold">Products</div>
            <div class="card-body">
                <% order.orderItems.forEach(item=> { %>
                    <div class="d-flex align-items-center border-bottom pb-3 mb-3">
                        <img src="/<%= item.product.productImage[0] %>" alt="<%= item.product.productName %>"
                            class="rounded me-3" style="width: 100px; height: 120px; object-fit: cover" />

                        <div>
                            <p class="mb-1 fw-bold">
                                <%= item.product.productName %>
                            </p>
                            <p class="mb-1">Qty: <%= item.quantity %>
                            </p>
                            <p class="mb-1">Price: ₹<%= item.price %>
                            </p>
                            <p class="mb-0">Status:
                                <span class="
                                <%= 
                                  item.itemStatus === 'Cancelled' ? 'text-danger' :
                                  item.itemStatus === 'Delivered' ? 'text-success' :
                                  item.itemStatus === 'Return Requested' ? 'text-warning' :
                                  item.itemStatus === 'Return Approved' ? 'text-warning' :
                                  item.itemStatus === 'Return Rejected' ? 'text-danger' :
                                  'text-primary'
                                %>">
                                    <%= item.itemStatus %>
                                </span>

                            </p>
                            <p>
                                <% if(item.itemStatus==='Delivered' ){ %>
                                    <button class="btn btn-warning btn-sm return-item-btn" data-bs-toggle="modal"
                                        data-bs-target="#returnItemModal" data-order-id="<%= order.orderId %>"
                                        data-item-id="<%= item._id %>">
                                        Return
                                    </button>
                                    <% } %>
                            </p>
                        </div>
                    </div>
                    <% }) %>
            </div>
        </div>
        <!-- Shipping Address -->
        <div class="card shadow-sm mb-4">
            <div class="card-header fw-bold">Shipping Address</div>
            <div class="card-body">
                <% if(order.selectedAddress) { %>
                    <p class="mb-1">
                        <%= order.selectedAddress.name %>
                    </p>
                    <p class="mb-1">
                        <%= order.selectedAddress.fullAddress %>, <%= order.selectedAddress.landmark %>
                    </p>
                    <p class="mb-1">
                        <%= order.selectedAddress.state %> - <%= order.selectedAddress.pincode %>
                    </p>
                    <p class="mb-0">Phone: <%= order.selectedAddress.phone %>
                    </p>
                    <% if(order.selectedAddress.altPhone){ %>
                        <p class="mb-0">Alt Phone: <%= order.selectedAddress.altPhone %>
                        </p>
                        <% } %>
                            <% } else {%>
                                <p class="text-danger">No address found.</p>
                                <% } %>
            </div>
        </div>
        <!-- Order Summary -->
        <div class="card shadow-sm mb-4">
            <div class="card-header fw-bold">Order Summary</div>
            <div class="card-body">
                <p class="d-flex justify-content-between">
                    <span>Subtotal:</span> <span>₹<%= subtotal %></span>
                </p>
                <p class="d-flex justify-content-between">
                    <span>Coupon Discount:</span> <span>-₹<%= discountAmount %> </span>
                </p>
                <p class="d-flex justify-content-between">
                    <span>Offer Discount:</span> <span>-₹<%= offerDiscountAmount %> </span>
                </p>
                <p class="d-flex justify-content-between">
                    <span>Delivery Charge:</span> <span>₹<%= deliveryCharge %></span>
                </p>
                <hr />
                <p class="d-flex justify-content-between fw-bold">
                    <span>Total:</span> <span>₹<%= finalAmount %> </span>
                </p>
            </div>
        </div>

        <!-- Payment Info -->
        <div class="card shadow-sm mb-4">
            <div class="card-header fw-bold">Payment Method</div>
            <div class="card-body">
                <p>
                    <%= order.paymentMethod==='cod' ? 'Cash on Delivery' : order.paymentMethod.toUpperCase() %>
                </p>
                <p>Status: <%= order.paymentStatus %>
                </p>
            </div>
        </div>
        <!-- Invoice Button -->
        <div class="text-end">
            <a href="/invoice/<%= order.orderId %>" class="btn btn-success">View Invoice</a>
        </div>
    </div>

    <!-- Return Order Modal -->
    <div class="modal fade" id="returnOrderModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <form class="modal-content" id="returnOrderForm">
                <input type="hidden" name="orderId" id="returnOrderId" />

                <div class="modal-header">
                    <h5 class="modal-title">Return Order</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <label class="form-label">Reason for Return</label>
                    <div>
                        <div class="form-check">
                            <input class="form-check-input return-reason" type="radio" name="reasonOption"
                                value="Product damaged" id="returnReason1" />
                            <label class="form-check-label" for="returnReason1">Product damaged</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input return-reason" type="radio" name="reasonOption"
                                value="Ordered by mistake" id="returnReason2" />
                            <label class="form-check-label" for="returnReason2">Ordered by mistake</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input return-reason" type="radio" name="reasonOption" value="Other"
                                id="returnReasonOther" />
                            <label class="form-check-label" for="returnReasonOther">Other</label>
                        </div>
                    </div>

                    <textarea class="form-control mt-2" name="reason" id="returnOtherReason" rows="3"
                        placeholder="Enter your reason..." style="display: none"></textarea>
                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-warning">Submit Return</button>
                </div>
            </form>
        </div>
    </div>



    <!-- Return Item Modal -->
    <div class="modal fade" id="returnItemModal" tabindex="-1">
        <div class="modal-dialog">
            <form class="modal-content" id="returnItemForm">
                <input type="hidden" id="returnItemOrderId">
                <input type="hidden" id="returnItemId">

                <div class="modal-header">
                    <h5 class="modal-title">Return Product</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <label class="form-label">Reason for Return</label>

                    <div class="form-check">
                        <input class="form-check-input item-reason" type="radio" name="itemReason"
                            value="Damaged product">
                        <label class="form-check-label">Damaged product</label>
                    </div>

                    <div class="form-check">
                        <input class="form-check-input item-reason" type="radio" name="itemReason"
                            value="Wrong item received">
                        <label class="form-check-label">Wrong item received</label>
                    </div>

                    <div class="form-check">
                        <input class="form-check-input item-reason" type="radio" name="itemReason" value="Other">
                        <label class="form-check-label">Other</label>
                    </div>

                    <textarea class="form-control mt-2" id="itemOtherReason" placeholder="Enter reason..."
                        style="display:none"></textarea>
                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-warning">Submit Return</button>
                </div>
            </form>
        </div>
    </div>




    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const returnOrderIdInput = document.getElementById("returnOrderId");
            const returnForm = document.getElementById("returnOrderForm");
            const returnReasonRadios = document.querySelectorAll(".return-reason");
            const returnOtherReason = document.getElementById("returnOtherReason");

            document
                .querySelectorAll('[data-bs-target="#returnOrderModal"]')
                .forEach((btn) => {
                    btn.addEventListener("click", () => {
                        const orderId = btn.dataset.order;
                        returnOrderIdInput.value = orderId;
                    });
                });

            returnReasonRadios.forEach((radio) => {
                radio.addEventListener("change", () => {
                    if (radio.value === "Other" && radio.checked) {
                        returnOtherReason.style.display = "block";
                        returnOtherReason.required = true;
                    } else {
                        returnOtherReason.style.display = "none";
                        returnOtherReason.required = false;
                    }
                });
            });

            // Submit form
            returnForm.addEventListener("submit", async (e) => {
                e.preventDefault();
                const orderId = returnOrderIdInput.value;
                const reason =
                    document.querySelector('input[name="reasonOption"]:checked')?.value ===
                        "Other"
                        ? returnOtherReason.value
                        : document.querySelector('input[name="reasonOption"]:checked')?.value;

                try {
                    const res = await fetch(`/return-order/${orderId}`, {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ reason }),
                    });
                    const data = await res.json();

                    if (data.success) {
                        Swal.fire({
                            icon: "success",
                            title: "Returned!",
                            text: data.message,
                            confirmButtonText: "OK",
                        }).then(() => {
                            returnModal.hide();
                            location.reload();
                        });
                    } else {
                        Swal.fire({ icon: "error", title: "Oops...", text: data.message });
                    }
                } catch (err) {
                    console.error(err);
                    Swal.fire({
                        icon: "error",
                        title: "Error",
                        text: "Something went wrong",
                    });
                }
            });




            const returnItemModal = new bootstrap.Modal(document.getElementById("returnItemModal"));

            document.querySelectorAll(".return-item-btn").forEach(btn => {
                btn.addEventListener("click", () => {
                    document.getElementById("returnItemOrderId").value = btn.dataset.orderId;
                    document.getElementById("returnItemId").value = btn.dataset.itemId;
                    returnItemModal.show();
                });
            });

            document.querySelectorAll(".item-reason").forEach(radio => {
                radio.addEventListener("change", () => {
                    document.getElementById("itemOtherReason").style.display =
                        radio.value === "Other" ? "block" : "none";
                });
            });

            // Submit item return
            document.getElementById("returnItemForm").addEventListener("submit", async e => {
                e.preventDefault();

                const orderId = document.getElementById("returnItemOrderId").value;
                const itemId = document.getElementById("returnItemId").value;

                const selected =
                    document.querySelector('input[name="itemReason"]:checked')?.value;

                const reason =
                    selected === "Other"
                        ? document.getElementById("itemOtherReason").value
                        : selected;

                const res = await fetch(`/return-item/${orderId}/${itemId}`, {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ reason }),
                });

                const data = await res.json();

                if (data.success) {
                    Swal.fire("Success", data.message, "success").then(() => location.reload());
                } else {
                    Swal.fire("Error", data.message, "error");
                }
            });

        });
    </script>

    <%-include("../../views/partials/user/footer")%>