<%-include("../../views/partials/user/header")%>
<link rel="stylesheet" href="/css/profile.css">

<div class="container-fluid">
  <div class="row">
    <!-- Sidebar -->
    <div class="col-md-3 sidebar">
      <h2>KRISHNA BCR71</h2>
      <a href="/userProfile" class="nav-link">My Profile</a>
      <a href="/address" class="nav-link">Address</a>
      <a href="#" class="nav-link">Orders</a>
      <a href="#" class="nav-link">Wishlist</a>
      <a href="#" class="nav-link">Wallet</a>
    </div>

    <!-- Profile Card -->
    <div class="col-md-9 d-flex justify-content-start align-items-start p-5">
      <div class="profile-card">

        <!-- Profile Image -->
        <div class="profile-img-wrapper">
            <!-- Placeholder (empty state) -->
            <div class="profile-img" id="profileImage">
              <%if(user.profileImage){%>
                <img src="/<%= user.profileImage %>" alt="Profile">
                <%}else{%>
                <i class="bi bi-person"></i>
                <%}%>
            </div>

            <!-- Upload button -->
            <label for="fileInput" class="upload-icon">
                <i class="bi bi-plus"></i>
            </label>
            <input type="file" id="fileInput" accept="image/*" hidden>
        </div>

        <h4 class="text-center"><%= user.name %></h4>
        <p class="text-center mb-1"><strong>Phone:</strong> <%= user.phone%></p>
        <p class="text-center"><strong>Email:</strong><%= user.email%></p>

        <div class="d-grid gap-2 mt-3">

          <a href="/change-name" class="btn btn-custom">Change Profile Name</a>
          <a href="/change-email" class="btn btn-custom">Change Email</a>
          <a href="/change-password" class="btn btn-custom">Change Password</a>

        </div>

        <div class="referral-box mt-4">
          Your Referral Code: <span id="referralCode">ABC123</span>
        </div>
      </div>
    </div>
  </div>
</div>


<script>

  

  document.getElementById('fileInput').addEventListener('change', async function(event) {
  const file = event.target.files[0];
  if (!file) return;

  // Send file to backend
  const formData = new FormData();
  formData.append('profileImage', file);

  try {
    const response = await fetch('/uploadProfileImage', {
      method: 'POST',
      body: formData,
    });

    const result = await response.json();

    if (result.success) {
      const profileDiv = document.getElementById('profileImage');
      profileDiv.innerHTML = `<img src="/${result.filename}" />`;
    } else {
      console.error("Upload failed:", result.message);
    }
  } catch (error) {
    console.error("Error uploading file:", error);
  }
});


</script>