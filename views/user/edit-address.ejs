<%-include("../../views/partials/user/header")%>
    <link rel="stylesheet" href="/css/add-address.css">


    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-8">

                <div class="card shadow-sm p-4">
                    <h3 class="mb-4 text-center">Edit Address</h3>
                    <form id="editAddressForm">
                        <input type="hidden" id="addressId" value="<%=address._id%>">

                        <div class="row g-3">

                            <!-- Address Type -->
                            <!-- <div class="col-md-4">
                                <label class="form-label">Address Type</label>
                                <input type="text" id="addressType" class="form-control" name="addressType"
                                    value="<%=address.addressType%>">
                                <div id="typeError" class="error-message text-danger"></div>
                            </div> -->

                            <!-- Name -->
                            <div class="col-md-4">
                                <label class="form-label">Name</label>
                                <input type="text" id="name" class="form-control" name="name" value="<%=address.name%>">
                                <div id="nameError" class="error-message text-danger"></div>
                            </div>

                            <!-- Landmark -->
                            <div class="col-md-4">
                                <label class="form-label">Landmark</label>
                                <input type="text" id="landmark" class="form-control" name="landmark"
                                    value="<%=address.landmark%>">
                                <div id="landmarkError" class="error-message text-danger"></div>
                            </div>

                            <!-- State -->
                            <div class="col-md-4">
                                <label class="form-label">State</label>
                                <input type="text" id="state" class="form-control" name="state"
                                    value="<%=address.state%>">
                                <div id="stateError" class="error-message text-danger"></div>
                            </div>

                            <!-- Pincode -->
                            <div class="col-md-4">
                                <label class="form-label">Pincode</label>
                                <input type="number" id="pincode" class="form-control" name="pincode"
                                    value="<%=address.pincode%>">
                                <div id="pincodeError" class="error-message text-danger"></div>
                            </div>

                            <!-- Full address -->
                            <div class="col-md-4">
                                <label class="form-label">Full Address</label>
                                <textarea id="fullAddress" class="form-control" name="fullAddress"
                                    rows="2"><%=address.fullAddress%></textarea>
                                <div id="fullAddressError" class="error-message text-danger"></div>
                            </div>

                            <!-- Phone -->
                            <div class="col-md-6">
                                <label class="form-label">Phone</label>
                                <input type="text" id="phone" class="form-control" name="phone"
                                    value="<%=address.phone%>">
                                <div id="phoneError" class="error-message text-danger"></div>
                            </div>

                            <!-- Alternate Phone -->
                            <div class="col-md-6">
                                <label class="form-label">Alternate Phone</label>
                                <input type="text" id="altPhone" class="form-control" name="altPhone"
                                    value="<%=address.altPhone%>">
                                <div id="altphoneError" class="error-message text-danger"></div>
                            </div>

                            <div class="col-12 text-center mt-3">
                                <button type="submit" class="btn px-5 btn-sub">Submit</button>
                            </div>

                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.getElementById('editAddressForm').addEventListener('submit', async function (e) {
            e.preventDefault()
            const addressId = document.getElementById('addressId').value
            document.querySelectorAll('.text-danger').forEach(el => el.textContent = '');
            let isValid = true;
            const addressType = document.getElementById('addressType');
            const name = document.getElementById('name');
            const landmark = document.getElementById('landmark');
            const state = document.getElementById('state');
            const pincode = document.getElementById('pincode');
            const fullAddress = document.getElementById('fullAddress');
            const phone = document.getElementById('phone');
            const altPhone = document.getElementById('altPhone');

            const typeError = document.getElementById('typeError')
            const nameError = document.getElementById('nameError')
            const landmarkError = document.getElementById('landmarkError')
            const stateError = document.getElementById('stateError')
            const pincodeError = document.getElementById('pincodeError')
            const fullAddressError = document.getElementById('fullAddressError')
            const phoneError = document.getElementById('phoneError')
            const altphoneError = document.getElementById('altphoneError')

            // Address Type
            if (addressType.value.trim() === '') {
                typeError.textContent = 'Address type is required';
                isValid = false;
            }

            // Name
            if (name.value.trim() === '') {
                nameError.textContent = 'Name is required';
                isValid = false;
            }

            // Landmark
            if (landmark.value.trim() === '') {
                landmarkError.textContent = 'Landmark is required';
                isValid = false;
            }

            // State
            if (state.value.trim() === '') {
                stateError.textContent = 'State is required';
                isValid = false;
            }

            // Pincode
            if (!/^[1-9]{1}[0-9]{2}\s?[0-9]{3}$/.test(pincode.value.trim())) {
                pincodeError.textContent = 'Enter a valid 6-digit pincode';
                isValid = false;
            }

            // Full Address
            if (fullAddress.value.trim().length < 10) {
                fullAddressError.textContent = 'Full address must be at least 10 characters';
                isValid = false;
            }

            // Phone
            if (!/^\d{10}$/.test(phone.value.trim())) {
                phoneError.textContent = 'Enter a valid 10-digit phone number';
                isValid = false;
            }

            // Alternate Phone (optional, but must be valid if filled)
            if (altPhone.value.trim() !== '' && !/^\d{10}$/.test(altPhone.value.trim())) {
                altphoneError.textContent = 'Enter a valid 10-digit alternate phone number';
                isValid = false;
            }

            if (phone.value.trim() === altPhone.value.trim()) {
                altphoneError.textContent = 'Phone number and alternate phone number should be different.'
                isValid = false;
            }

            // Stop form if validation fails
            if (!isValid) return

            // Form data
            const formData = {
                addressType: addressType.value.trim(),
                name: name.value.trim(),
                landmark: landmark.value.trim(),
                state: state.value.trim(),
                pincode: pincode.value.trim(),
                fullAddress: fullAddress.value.trim(),
                phone: phone.value.trim(),
                altPhone: altPhone.value.trim()
            };


            try {
                const response = await fetch(`/edit-address/${addressId}`, {
                    method: "PATCH",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(formData)
                });

                const result = await response.json();

                if (result.success) {
                    Swal.fire({
                        icon: "success",
                        title: "Updated!",
                        text: result.message,
                        confirmButtonColor: "#3085d6"
                    }).then(() => {
                        // Redirect back to address list after success
                        window.location.href = "/address";
                    });
                } else {
                    Swal.fire({
                        icon: "error",
                        title: "Error",
                        text: result.message
                    });
                }
            } catch (err) {
                Swal.fire({
                    icon: "error",
                    title: "Oops...",
                    text: "Something went wrong!"
                });
            }



        });
    </script>