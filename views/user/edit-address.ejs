<%-include("../../views/partials/user/header")%>
<link rel="stylesheet" href="/css/add-address.css" />

<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <div class="card shadow-sm p-4">
        <h3 class="mb-4 text-center">Edit Address</h3>
        <form id="editAddressForm">
          <input type="hidden" id="addressId" value="<%=address._id%>" />

          <input
            type="hidden"
            id="source"
            name="source"
            value="<%= source %>"
          />

          <div class="row g-3">
            <!-- Name -->
            <div class="col-md-4">
              <label class="form-label">Name</label>
              <input
                type="text"
                id="name"
                class="form-control"
                name="name"
                value="<%=address.name%>"
              />
            </div>

            <!-- Landmark -->
            <div class="col-md-4">
              <label class="form-label">Landmark</label>
              <input
                type="text"
                id="landmark"
                class="form-control"
                name="landmark"
                value="<%=address.landmark%>"
              />
            </div>

            <!-- State -->
            <div class="col-md-4">
              <label class="form-label">State</label>
              <input
                type="text"
                id="state"
                class="form-control"
                name="state"
                value="<%=address.state%>"
              />
            </div>

            <!-- Pincode -->
            <div class="col-md-4">
              <label class="form-label">Pincode</label>
              <input
                type="text"
                id="pincode"
                class="form-control"
                name="pincode"
                value="<%=address.pincode%>"
              />
            </div>

            <!-- Full address -->
            <div class="col-md-4">
              <label class="form-label">Full Address</label>
              <textarea
                id="fullAddress"
                class="form-control"
                name="fullAddress"
                rows="2"><%=address.fullAddress%></textarea>
            </div>

            <!-- Phone -->
            <div class="col-md-6">
              <label class="form-label">Phone</label>
              <input
                type="text"
                id="phone"
                class="form-control"
                name="phone"
                value="<%=address.phone%>"
              />
            </div>

            <!-- Alternate Phone -->
            <div class="col-md-6">
              <label class="form-label">Alternate Phone</label>
              <input
                type="text"
                id="altPhone"
                class="form-control"
                name="altPhone"
                value="<%=address.altPhone%>"
              />
            </div>

            <div class="col-12 text-center mt-3">
              <button type="submit" class="btn px-5 btn-sub">Submit</button>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
  document
    .getElementById("editAddressForm")
    .addEventListener("submit", async function (e) {
      e.preventDefault();
      const addressId = document.getElementById("addressId").value;

      const name = document.getElementById("name").value.trim();
      const landmark = document.getElementById("landmark").value.trim();
      const state = document.getElementById("state").value.trim();
      const pincode = document.getElementById("pincode").value.trim();
      const fullAddress = document.getElementById("fullAddress").value.trim();
      const phone = document.getElementById("phone").value.trim();
      const altPhone = document.getElementById("altPhone").value.trim();

      const source = document.getElementById("source").value;

      if (!name || !landmark || !state || !pincode || !fullAddress || !phone) {
        return Swal.fire("Error", "All fields are required", "error");
      }

      // Pincode
      if (!/^[1-9]{1}[0-9]{2}\s?[0-9]{3}$/.test(pincode)) {
        return Swal.fire("Error", "Enter a valid 6-digit pincode", "error");
      }

      // Full Address
      if (fullAddress.length < 10) {
        return Swal.fire(
          "Error",
          "Full address must be at least 10 characters",
          "error"
        );
      }

      // Phone
      if (!/^\d{10}$/.test(phone)) {
        return Swal.fire(
          "Error",
          "Enter a valid 10-digit phone number",
          "error"
        );
      }

      // Alternate Phone (optional, but must be valid if filled)
      if (altPhone !== "" && !/^\d{10}$/.test(altPhone)) {
        return Swal.fire(
          "Error",
          "Enter a valid 10-digit alternate phone number",
          "error"
        );
      }

      if (phone === altPhone) {
        return Swal.fire(
          "Error",
          "Phone number and alternate phone number should be different.",
          "error"
        );
      }

      // Form data
      const formData = {
        name: name,
        landmark: landmark,
        state: state,
        pincode: pincode,
        fullAddress: fullAddress,
        phone: phone,
        altPhone: altPhone,
        source,
      };

      try {
        const response = await fetch(`/edit-address/${addressId}`, {
          method: "PATCH",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(formData),
        });

        const result = await response.json();

        if (result.success) {
          Swal.fire({
            icon: "success",
            title: "Updated!",
            text: result.message,
            confirmButtonColor: "#3085d6",
          }).then(() => {
            if (source === "checkout") {
              window.location.href = "/checkout";
            } else {
              window.location.href = "/address";
            }
          });
        } else {
          Swal.fire({
            icon: "error",
            title: "Error",
            text: result.message,
          });
        }
      } catch (err) {
        Swal.fire({
          icon: "error",
          title: "Oops...",
          text: "Something went wrong!",
        });
      }
    });
</script>
