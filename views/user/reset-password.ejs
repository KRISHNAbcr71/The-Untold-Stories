<%-include("../../views/partials/user/header")%>
<link rel="stylesheet" href="/css/resetPassword.css">

<div class="reset-password-page">
  <div class="container min-vh-100 d-flex justify-content-center align-items-center">
    <div class="row w-100">
      <div class="col-md-8 col-lg-5 col-xl-4 mx-auto">
        <div class="reset-card">
          <!-- Decorative top accent -->
          <div class="card-accent"></div>
          
          <div class="card-body p-4 p-xl-5">
            <!-- Header with icon -->
            <div class="text-center mb-4">
              <div class="lock-icon-wrapper mb-3">
                <i class="fas fa-lock"></i>
              </div>
              <h3 class="reset-title">Reset Password</h3>
              <p class="reset-subtitle">Enter your new password below</p>
            </div>
            
            <!-- Form -->
            <form action="/reset-password" method="POST" id="passwordResetForm">
              <!-- New Password Field -->
              <div class="input-group-custom mb-4">
                <label for="password" class="form-label-custom">
                  <i class="fas fa-key"></i>
                  New Password
                </label>
                <div class="input-wrapper">
                  <i class="fas fa-lock input-icon"></i>
                  <input type="password" class="password-input" id="password" name="password" placeholder="Enter new password">
                  <span id="toggleIcon" class="eye-toggle-custom">
                    <i class="far fa-eye"></i>
                  </span>
                </div>
                <div id="error1" class="error-message-custom">
                  <i class="fas fa-exclamation-circle"></i>
                  <span></span>
                </div>
              </div>

              <!-- Confirm Password Field -->
              <div class="input-group-custom mb-4">
                <label for="confirmPassword" class="form-label-custom">
                  <i class="fas fa-check-circle"></i>
                  Confirm Password
                </label>
                <div class="input-wrapper">
                  <i class="fas fa-lock input-icon"></i>
                  <input type="password" class="password-input" id="confirmPassword" name="confirmPassword" placeholder="Re-enter password">
                </div>
                <div id="error2" class="error-message-custom">
                  <i class="fas fa-exclamation-circle"></i>
                  <span></span>
                </div>
              </div>

              <!-- Password strength indicator (visual enhancement only) -->
              <div class="password-strength mb-4" id="passwordStrength">
                <div class="strength-bar"></div>
                <div class="strength-text"></div>
              </div>

              <!-- Submit Button -->
              <button type="submit" class="btn-change-password" id="submitBtn">
                <i class="fas fa-sync-alt me-2"></i>
                Change Password
                <i class="fas fa-arrow-right ms-2"></i>
              </button>
            </form>

            <!-- Signup Link -->
            <div class="signup-link-enhanced mt-4">
              <i class="fas fa-user-plus"></i>
              Don't have an account? 
              <a href="/signup">
                Sign up
                <i class="fas fa-arrow-right"></i>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Font Awesome (if not already included) -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

<script>
  document.addEventListener('DOMContentLoaded', function(){
    const form = document.getElementById('passwordResetForm');
    const password = document.getElementById('password');
    const cpassword = document.getElementById('confirmPassword');
    const passwordError = document.getElementById('error1');
    const cpasswordError = document.getElementById('error2');
    const toggleIcon = document.getElementById('toggleIcon');
    const submitBtn = document.getElementById('submitBtn');
    const strengthBar = document.querySelector('.strength-bar');
    const strengthText = document.querySelector('.strength-text');

    // Clear errors on input
    password.addEventListener('input', () => {
      passwordError.style.display = 'none';
      updatePasswordStrength(password.value);
    });
    
    cpassword.addEventListener('input', () => {
      cpasswordError.style.display = 'none';
    });

    // Password strength indicator
    function updatePasswordStrength(pass) {
      if (!pass) {
        strengthBar.style.width = '0%';
        strengthBar.style.backgroundColor = '#e0e0e0';
        strengthText.textContent = '';
        return;
      }

      let strength = 0;
      if (pass.length >= 8) strength += 25;
      if (pass.match(/[a-z]+/)) strength += 25;
      if (pass.match(/[A-Z]+/)) strength += 25;
      if (pass.match(/[0-9]+/)) strength += 25;
      if (pass.match(/[$@#&!]+/)) strength += 25;

      strength = Math.min(strength, 100);

      strengthBar.style.width = strength + '%';
      
      if (strength < 25) {
        strengthBar.style.backgroundColor = '#ff4d4f';
        strengthText.textContent = 'Too weak';
      } else if (strength < 50) {
        strengthBar.style.backgroundColor = '#faad14';
        strengthText.textContent = 'Weak';
      } else if (strength < 75) {
        strengthBar.style.backgroundColor = '#1890ff';
        strengthText.textContent = 'Good';
      } else {
        strengthBar.style.backgroundColor = '#52c41a';
        strengthText.textContent = 'Strong';
      }
    }

    // Toggle password visibility
    toggleIcon.addEventListener('click', () => {
      if(password.value.trim() == ''){
        return;
      }

      if(password.type === 'password'){
        password.type = 'text';
        toggleIcon.innerHTML = '<i class="far fa-eye-slash"></i>';
      } else {
        password.type = 'password';
        toggleIcon.innerHTML = '<i class="far fa-eye"></i>';
      }
    });

    // Form validation
    form.addEventListener('submit', function(e){
      let valid = true;
      const passwordValue = password.value.trim();
      const cpasswordValue = cpassword.value.trim();

      // Reset error displays
      passwordError.style.display = 'none';
      cpasswordError.style.display = 'none';

      // Validate password
      if(passwordValue === ''){
        passwordError.querySelector('span').textContent = 'Please enter a password';
        passwordError.style.display = 'flex';
        valid = false;
      } else if(passwordValue.length < 8){
        passwordError.querySelector('span').textContent = 'Password must be at least 8 characters';
        passwordError.style.display = 'flex';
        valid = false;
      }

      // Validate confirm password
      if(cpasswordValue === ''){
        cpasswordError.querySelector('span').textContent = 'Please confirm your password';
        cpasswordError.style.display = 'flex';
        valid = false;
      } else if(passwordValue !== cpasswordValue){
        cpasswordError.querySelector('span').textContent = 'Passwords do not match';
        cpasswordError.style.display = 'flex';
        valid = false;
      }

      if(!valid){
        e.preventDefault();
        // Shake animation on invalid fields
        if (passwordError.style.display === 'flex') {
          password.closest('.input-group-custom').classList.add('shake');
          setTimeout(() => password.closest('.input-group-custom').classList.remove('shake'), 500);
        }
        if (cpasswordError.style.display === 'flex') {
          cpassword.closest('.input-group-custom').classList.add('shake');
          setTimeout(() => cpassword.closest('.input-group-custom').classList.remove('shake'), 500);
        }
      } else {
        submitBtn.classList.add('btn-loading');
        submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Processing...';
      }
    });
  });
</script>

<%-include("../../views/partials/user/footer")%>