<%- include("../partials/user/header") %>
<link rel="stylesheet" href="/css/change-name.css">
    
<div class="d-flex justify-content-center align-items-center vh-100">
  <div class="card shadow-lg p-4" style="width: 400px; border-radius: 15px;">
    <div class="card-body">
      <h3 class="card-title text-center mb-4">Change Email</h3>
      <form action="/change-email" method="POST" id="form">
        <div class="mb-3">
          <input type="text" id="email" name="email" class="form-control" placeholder="Enter your current email :-">
          <div class="text-danger" id="email-error"></div>
        </div>
        <div class="d-flex gap-2">
          <button type="submit" class="btn btn-save flex-fill">Send OTP</button>
        </div>
      </form>
    </div>
  </div>
</div>


<script>

  const emailInput = document.getElementById('email')
  const emailError = document.getElementById('email-error')

  emailInput.addEventListener('input', () => { emailError.textContent = ''})


  document.getElementById('form').addEventListener('submit', function(e){

    emailError.textContent = ''

    const email = emailInput.value.trim();

    if(!email){
      e.preventDefault()
      emailError.textContent = 'Email is required'
      return
    }

    const emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if(!emailPattern.test(email)) {
      e.preventDefault()
      emailError.textContent = 'Please enter a valid email address'
    }

  });
  
</script>