<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="Cache-Control" content="no-store, no-cache, must-revalidate" />
  <meta http-equiv="Pragma" content="no-cache" />
  <meta http-equiv="Expires" content="0" />
  <title>Email verification • OTP</title>

  <!-- Font Awesome & SweetAlert2 (kept as original) -->
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" />

  <style>
    /* ===== base & colors (unaltered) ===== */
    body {
      font-family: 'Segoe UI', Roboto, system-ui, sans-serif;
      background-color: #f4f1ea;  /* unchanged */
      margin: 0;
      padding: 0;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
    }

    .container {
      background-color: #e9e4d9;   /* fixed card color */
      padding: 2rem 2.25rem;
      border-radius: 28px;
      box-shadow: 0 15px 35px -10px rgba(0, 0, 0, 0.15), 0 4px 10px rgba(0, 0, 0, 0.05);
      width: 100%;
      max-width: 420px;
      transition: transform 0.2s ease;
    }

    /* ===== refined interior ===== */
    h3 {
      text-align: center;
      margin: 0 0 0.5rem 0;
      color: #2c2c2c;
      font-weight: 550;
      font-size: 1.9rem;
      letter-spacing: -0.5px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }

    h3 i {
      color: #fca311;
      font-size: 2rem;
    }

    .sub-head {
      text-align: center;
      color: #5c5b5b;
      font-size: 0.95rem;
      margin-bottom: 1.8rem;
      border-bottom: 1px dashed #cdc7bb;
      padding-bottom: 0.9rem;
    }

    .form-group {
      margin-bottom: 1.6rem;
      position: relative;
    }

    label {
      display: flex;
      align-items: center;
      gap: 6px;
      margin-bottom: 8px;
      color: #3d3d3d;
      font-weight: 500;
      font-size: 0.95rem;
    }

    label i {
      color: #fca311;
      font-size: 0.9rem;
      width: 18px;
    }

    /* OTP input — modern but clean */
    .otp-input-wrapper {
      position: relative;
      display: flex;
      align-items: center;
    }

    input[type="text"] {
      width: 100%;
      padding: 14px 16px;
      font-size: 1.1rem;
      border: 1.5px solid #d3cdc0;
      border-radius: 18px;
      background-color: #fefcf8;
      transition: all 0.2s;
      box-sizing: border-box;
      font-weight: 500;
      letter-spacing: 2px;
      text-align: center;
      caret-color: #fca311;
    }

    input[type="text"]:focus {
      border-color: #fca311;
      outline: none;
      background-color: #ffffff;
      box-shadow: 0 0 0 4px rgba(252, 163, 17, 0.1);
    }

    input[type="text"]::placeholder {
      letter-spacing: normal;
      font-weight: 300;
      color: #b1aa9e;
      font-size: 0.95rem;
    }

    /* button primary — verify */
    .btn {
      width: 100%;
      padding: 14px 10px;
      border: none;
      border-radius: 18px;
      font-size: 1.05rem;
      font-weight: 600;
      cursor: pointer;
      transition: 0.2s;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
    }

    .btn-primary {
      background-color: #fca311;
      color: white;
      box-shadow: 0 8px 18px -6px rgba(252, 163, 17, 0.4);
    }

    .btn-primary:hover {
      background-color: #e8910e;
      transform: scale(1.02);
      box-shadow: 0 12px 22px -8px rgba(252, 163, 17, 0.5);
    }

    .btn-primary:active {
      transform: scale(0.98);
    }

    /* timer + resend area — refined */
    .otp-timer {
      margin-top: 10px;
      font-size: 0.95rem;
      color: #6b6258;
      text-align: center;
      background: #dfd9cf;
      padding: 8px 12px;
      border-radius: 40px;
      display: inline-block;
      width: auto;
      margin-left: auto;
      margin-right: auto;
    }

    .timer-flex {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      background: #dfd9cf;
      border-radius: 30px;
      padding: 5px 15px;
    }

    .timer-flex i {
      color: #fca311;
      font-size: 0.9rem;
    }

    #timerValue {
      font-weight: 700;
      color: #2f2e2b;
      min-width: 70px;
      display: inline-block;
      text-align: center;
    }

    /* resend button — exactly same color semantics, but better spacing */
    .btn-secondary {
      background-color: #d1d5db;
      color: #1f2937;
      transition: 0.2s;
      margin-top: 16px;
      border-radius: 18px;
      font-weight: 500;
      border: 1px solid transparent;
    }

    .btn-secondary:not(:disabled):hover {
      background-color: #b9c0ca;
      color: #111;
      border-color: #a0a9b5;
    }

    .btn-secondary:disabled {
      background-color: #e5e7eb;
      color: #9ca3af;
      cursor: not-allowed;
      opacity: 1;
      border-color: #d4d8dd;
    }

    /* link section */
    .text-muted {
      font-size: 0.95rem;
      text-align: center;
      margin-top: 28px;
      color: #5f5b55;
      border-top: 1px solid #d6cfc2;
      padding-top: 22px;
    }

    .text-muted a {
      color: #fca311;
      text-decoration: none;
      font-weight: 600;
      margin-left: 4px;
      border-bottom: 1.5px dotted transparent;
      transition: 0.15s;
    }

    .text-muted a:hover {
      border-bottom-color: #fca311;
    }

    /* subtle extra polish */
    .note {
      font-size: 0.8rem;
      color: #8e877d;
      margin-top: 5px;
      display: flex;
      gap: 5px;
      align-items: center;
      justify-content: center;
    }

    .note i {
      font-size: 0.7rem;
    }
  </style>

</head>
<body>
  <div class="container">
    <h3>
      <i class="fas fa-envelope-open-text"></i> 
      Verify email
    </h3>
    <div class="sub-head">
      <i class="fas fa-key" style="opacity:0.7;"></i> Enter the 6-digit code
    </div>

    <form id="otpForm" action="/verify-otp" method="post" onsubmit="return validateOtpForm()" novalidate>
      <div class="form-group">
        <label for="otp">
          <i class="fas fa-lock"></i> One-time password
        </label>
        <div class="otp-input-wrapper">
          <input type="text" id="otp" name="otp" required maxlength="6" pattern="\d*" 
                 placeholder="• • • • • •" inputmode="numeric" autocomplete="off">
        </div>
        <div class="note">
          <i class="fas fa-info-circle"></i> 
          <span>check your inbox (and spam)</span>
        </div>
      </div>

      <button type="submit" class="btn btn-primary">
        <i class="fas fa-check-circle"></i> Verify email
      </button>

      <div class="form-group text-center" style="margin-bottom:0;">
        <div id="otpTimer" class="otp-timer" style="display:flex; justify-content:center;">
          <span class="timer-flex">
            <i class="far fa-clock"></i>
            <span id="timerValue">60</span>
          </span>
        </div>
        <button type="button" class="btn btn-secondary" id="resendBtn" onclick="resendOtp()">
          <i class="fas fa-redo-alt"></i> Resend new code
        </button>
      </div>
    </form>

    <div class="text-muted">
      <i class="fas fa-shield-alt" style="opacity:0.5;"></i>
      Already verified? <a href="/login">Login now →</a>
    </div>
  </div>


  <script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script>

    let otpSentAt = new Date('<%= otpSentAt %>');
    let countdown;
    const timerSpan = document.getElementById("timerValue");
    const resendBtn = document.getElementById("resendBtn");

    function startTimer() {
      clearInterval(countdown);

      const now = new Date();
      const secondsPassed = Math.floor((now - otpSentAt) / 1000);
      let timeLeft = Math.max(60 - secondsPassed, 0);

      if (timeLeft <= 0) {
        resendBtn.disabled = false;
        timerSpan.textContent = "Expired";
        return;
      }

      resendBtn.disabled = true;
      timerSpan.textContent = timeLeft;

      countdown = setInterval(() => {
        timeLeft--;
        timerSpan.textContent = timeLeft;

        if (timeLeft <= 0) {
          clearInterval(countdown);
          resendBtn.disabled = false;
          timerSpan.textContent = "Expired";
        }
      }, 1000);
    }

    document.addEventListener('DOMContentLoaded', startTimer);

    function validateOtpForm() {
      const otpInput = document.getElementById('otp').value.trim();

      if (!otpInput) {
        Swal.fire({
          icon: 'error',
          title: 'Missing OTP',
          text: 'Please enter the OTP to continue.',
          confirmButtonColor: '#fca311'
        });
        return false;
      }

      $.ajax({
        type: 'POST',
        url: '/verify-otp',
        data: { otp: otpInput },

        success: function (response) {
          if (response.success) {
            Swal.fire({
              icon: 'success',
              title: 'OTP verified',
              showConfirmButton: false,
              timer: 1500,
              background: '#e9e4d9',
              iconColor: '#fca311'
            }).then(() => {
              window.location.href = response.redirectUrl
            });
          } else {
            Swal.fire({
              icon: 'error',
              title: 'Verification failed',
              text: response.message || 'Invalid OTP. Please try again.',
              confirmButtonColor: '#fca311'
            })
          }
        }, error: function (xhr) {

          if (xhr.status === 429 && xhr.responseJSON) {
    Swal.fire({
      icon: 'error',
      title: 'Too many attempts',
      text: xhr.responseJSON.message,
      confirmButtonColor: '#fca311'
    });
  } else {
    Swal.fire({
      icon: 'error',
      title: 'Server Error',
      text: 'Something went wrong. Please try again later.',
      confirmButtonColor: '#fca311'
    });
  }

        }
      })
      return false;
    }

    function resendOtp() {
      $.ajax({
        type: 'POST',
        url: '/resend-otp',

        success: function (response) {
          if (response.success) {
            Swal.fire({
              icon: 'success',
              title: 'OTP Sent',
              text: 'A new OTP has been sent to your email.',
              showConfirmButton: false,
              timer: 1500,
              background: '#e9e4d9',
              iconColor: '#fca311'
            });
            if (response.otpSentAt) {
              otpSentAt = new Date(response.otpSentAt);
              startTimer();
            }
          } else {
            Swal.fire({
              icon: 'error',
              title: 'Failed to Resend',
              text: response.message || 'Unable to resend OTP. Please try again.',
              confirmButtonColor: '#fca311'
            });
          }
        },
        error: function (xhr) {

          if (xhr.status === 429 && xhr.responseJSON) {
    Swal.fire({
      icon: 'error',
      title: 'Too many attempts',
      text: xhr.responseJSON.message,
      confirmButtonColor: '#fca311'
    });
  } else {
    Swal.fire({
      icon: 'error',
      title: 'Server Error',
      text: 'Something went wrong. Please try again later.',
      confirmButtonColor: '#fca311'
    });
  }


        }
      });
    }
  </script>

</body>
</html>