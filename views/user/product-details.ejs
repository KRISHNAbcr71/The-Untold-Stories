    async function toggleWishlist(button, productId) {
  try {
    const response = await fetch(`/add-to-wishlist/${productId}`, {
      method: "POST",
      headers: { "Content-Type": "application/json" }
    });

    const result = await response.json();

    //NOT LOGGED IN
    if (response.status === 401) {
      Swal.fire({
        icon: 'warning',
        title: 'Login required',
        text: result.message,
        confirmButtonText: 'Ok',
      })
      return;
    }

    // SUCCESS
    if (response.ok) {
      const icon = button.querySelector("i");

      button.classList.toggle("wishlist-active");
      icon.classList.toggle("fa-solid");
      icon.classList.toggle("fa-regular");

      Swal.fire({
        icon: 'success',
        title: result.message,
        showConfirmButton: false,
        timer: 1200
      });
    }

  } catch (error) {
    Swal.fire({
      icon: 'error',
      title: 'Oops!',
      text: 'Something went wrong.'
    });
  }
}




    // Share Product Function
    function shareProduct() {
        if (navigator.share) {
            navigator.share({
                title: '<%= product.productName %>',
                text: 'Check out this amazing book!',
                url: window.location.href,
            });
        } else {
            navigator.clipboard.writeText(window.location.href);
            Swal.fire({
                icon: 'success',
                title: 'Link Copied!',
                text: 'Product link copied to clipboard',
                showConfirmButton: false,
                timer: 2000,
                customClass: {
                    popup: 'rounded-4'
                }
            });
        }
    }

    // Submit Review Function
