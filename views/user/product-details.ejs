    // Add to Cart Function
    async function addToCart(productId) {
        try {
            const response = await fetch(`/add-to-cart/${productId}`, {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                }
            });

            const result = await response.json();

            if (response.ok) {
                Swal.fire({
                    icon: 'success',
                    title: 'Added to Cart',
                    text: result.message,
                    showConfirmButton: false,
                    timer: 2000,
                    customClass: {
                        popup: 'rounded-4'
                    }
                });
                updateCartCount();
            } else {
                Swal.fire({
                    icon: 'error',
                    title: 'Oops!',
                    text: result.message || "Could not add product to cart",
                    customClass: {
                        popup: 'rounded-4'
                    }
                });
            }
        } catch (error) {
            Swal.fire({
                icon: 'error',
                title: 'Oops!',
                text: 'Something went wrong while adding to cart.',
                customClass: {
                    popup: 'rounded-4'
                }
            });
        }
    }

