<%-include("../../views/partials/user/header")%>
    <link rel="stylesheet" href="/css/product-details.css">





    <!-- Breadcrumb Section Begin -->
    <section class="breadcrumb-section py-4">
        <div class="container">
            <div
                class="breadcrumb-content d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center">
                <nav class="breadcrumb-nav">
                    <a href="/">Home</a>
                    <span class="breadcrumb-separator">/</span>
                    <a href="/shop">Shop</a>
                    <span class="breadcrumb-separator">/</span>
                    <span class="current">Product</span>
                    
                </nav>
            </div>
        </div>
    </section>
    <!-- Breadcrumb Section End -->



    <div class="container py-5">
        <div class="row">

            <!-- Product Image -->
            <div class="image-section">
                <img id="mainImage" src="/<%= product.productImage[0] %>" alt="Product Image" class="main-image">
                <div id="zoomLens"></div>
                <div class="thumbnail-container">
                    <%for(let i=0; i<product.productImage.length; i++){%>
                        <img src="/<%= product.productImage[i] %>" data-image="/<%= product.productImage[i] %>"
                            class="active" alt="Product Image">
                        <%}%>
                </div>
            </div>

            <!-- Product Info -->
            <div class="col-md-7">
                <h2>
                    <%= product.productName %>
                </h2>

                <!-- Ratings -->
                <div class="rating mb-2">
                    <p class="text-muted">No ratings yet. Be the first to rate this product!</p>
                </div>

                <!-- Price & Discounts -->
                <h3 class="text-success">₹<%= product.price %>
                        <!-- <small class="text-muted"><del>₹399.00</del></small> -->
                </h3>
                <p class="discount">Get 10% off on orders above ₹500</p>

                <!-- Stock Status -->
                <% if (product.quantity> 0) { %>
                    <% if (product.quantity <=10) { %>
                        <p class="text-danger">Only <%= product.quantity %> left in stock!</p>
                        <% } else { %>
                            <p><strong>Stock:</strong> <span class="text-success">Available</span> </p>
                            <% } %>
                                <% }else{%>
                                    <p><strong>Stock:</strong> <span class="text-danger">Out of stock</span> </p>
                                    <%}%>



                                        <p><strong>Details:</strong></p>

                                        <ul style="list-style-type: none;">
                                            <li><i class="fas fa-feather-alt"></i> <span class="text-primary">Author:
                                                    <%=product.author%>
                                                </span></li>
                                            <li><i class="fas fa-book"></i><span class="text-primary"> Genre:
                                                    <%=product.category.name%>
                                                </span></li>
                                            <li><i class="fas fa-truck"></i><span class="text-primary"> Free
                                                    Delivery</span>
                                            </li>
                                            <li><i class="fas fa-sync-alt"></i><span class="text-primary"> 10 Days
                                                    Replacement</span></li>
                                            <li><i class="fas fa-credit-card"></i><span class="text-primary"> Cash on
                                                    Delivery available</span></li>
                                        </ul>

                                        <!-- Add to Cart Button -->
                                        <!-- <form action="/add-to-cart/<%= product._id %>" method="post" onsubmit="return checkProductStatus()">
                                        <button type="submit" class="btn-cart-wishlist">Add to Cart</button>
                                    </form>

                                    <form action="/add-to-wishlist/<%= product._id %>" method="post" onsubmit="return checkProductStatus()">
                                        <button type="submit" class="btn-cart-wishlist">Add to Wishlist</button>
                                    </form> -->
                                        <!-- Add to Cart Button -->
                                        <button type="button" class="btn-cart-wishlist"
                                            onclick="addToCart('<%= product._id %>')">
                                            Add to Cart
                                        </button>

                                        <!-- Add to Wishlist Button -->
                                        <button type="button" class="btn-cart-wishlist"
                                            onclick="addToWishlist('<%= product._id %>')">
                                            Add to Wishlist
                                        </button>

                                        <div>
                                            <form action="/buy-now/<%= product._id %>" method="post">
                                                <button type="submit" class="btn-buy">Buy Now</button>
                                            </form>
                                        </div>

            </div>

        </div>


        <!-- Reviews Section -->
        <div class="row mt-5">
            <div class="col-12">
                <h4>Customer Reviews</h4>
                <p class="text-muted">No reviews yet. Be the first to review this product!</p>
            </div>
        </div>

        <!-- Related Products -->
        <div class="row mt-5">
            <h4>Related Products</h4>
            <%if(relatedProducts && relatedProducts.length> 0){%>
                <% relatedProducts.forEach(rp=>{ %>
                    <div class="col-md-3 mb-4 product-card">

                        <div class="card related-card h-100 ">
                            <img src="/<%= rp.productImage[0]%>" class="card-img-top" alt="Product">
                            <div class="card-body text-center">
                                <h6 class="card-title">
                                    <%= rp.productName%>
                                </h6>
                                <p class="price">
                                    ₹<%= rp.price%>
                                </p>
                                <!-- <button class="btn btn-outline-primary btn-sm">View</button> -->
                                <a href="/productDetails?id=<%=rp._id%>" class="btn btn-sm btn-view">View</a>
                            </div>
                        </div>
                    </div>
                    <%})%>

                        <%}else{%>
                            <p class="text-muted">No related products found.</p>
                            <%}%>


        </div>
    </div>







    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">




    <script>

        const mainImage = document.getElementById('mainImage');
        const thumbnails = document.querySelectorAll('.thumbnail-container img');
        const lens = document.getElementById("zoomLens");
        const zoomLevel = 2;

        // Thumbnail click change
        thumbnails.forEach(thumbnail => {
            thumbnail.addEventListener('click', () => {
                const newSrc = thumbnail.getAttribute('data-image');
                mainImage.src = newSrc;

                thumbnails.forEach(t => t.classList.remove('active'));
                thumbnail.classList.add('active');
            });
        });

        // Zoom Lens
        mainImage.addEventListener("mousemove", moveLens);
        lens.addEventListener("mousemove", moveLens);
        mainImage.addEventListener("mouseenter", () => lens.style.display = "block");
        mainImage.addEventListener("mouseleave", () => lens.style.display = "none");

        function moveLens(e) {
            const rect = mainImage.getBoundingClientRect();
            const x = e.clientX - rect.left;
            const y = e.clientY - rect.top;

            let lensX = x - lens.offsetWidth / 2;
            let lensY = y - lens.offsetHeight / 2;

            // Prevent lens from going outside image
            if (lensX < 0) lensX = 0;
            if (lensY < 0) lensY = 0;
            if (lensX > rect.width - lens.offsetWidth) lensX = rect.width - lens.offsetWidth;
            if (lensY > rect.height - lens.offsetHeight) lensY = rect.height - lens.offsetHeight;

            lens.style.left = `${lensX}px`;
            lens.style.top = `${lensY}px`;

            // Apply zoom effect
            lens.style.backgroundImage = `url('${mainImage.src}')`;
            lens.style.backgroundSize = `${mainImage.width * zoomLevel}px ${mainImage.height * zoomLevel}px`;
            lens.style.backgroundPosition = `-${x * zoomLevel - lens.offsetWidth / 2}px -${y * zoomLevel - lens.offsetHeight / 2}px`;
        }




        async function addToCart(productId) {
            try {
                const response = await fetch(`/add-to-cart/${productId}`, {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    }
                });

                const result = await response.json();

                if (response.ok) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Added to Cart',
                        text: result.message,
                        showConfirmButton: false,
                        timer: 2000
                    });
                    updateCounts();
                }else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Oops!',
                        text: result.message || "Could not add product to cart"
                    });
                }
            } catch (error) {
                Swal.fire({
                    icon: 'error',
                    title: 'Oops!',
                    text: 'Something went wrong while adding to cart.'
                });
            }
        }

        

        async function addToWishlist(productId) {
            try {
                const response = await fetch(`/add-to-wishlist/${productId}`, {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    }
                });

                const result = await response.json();

                if (response.ok) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Added to Wishlist',
                        text: result.message,
                        showConfirmButton: false,
                        timer: 2000
                    });
                    updateCounts();
                }else{
                    Swal.fire({
                        icon: 'warning',
                        title: 'Notice',
                        text: result.message,
                        showConfirmButton: true
                    })
                }
            } catch (error) {
                Swal.fire({
                    icon: 'error',
                    title: 'Oops!',
                    text: 'Something went wrong while adding to wishlist.'
                });
            }
        }


    </script>


    <%-include("../../views/partials/user/footer")%>