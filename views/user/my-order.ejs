<%-include("../../views/partials/user/header")%>
  <link rel="stylesheet" href="/css/my-order.css">

  <div class="container-fluid">
    <div class="row min-vh-100">
      <!-- Sidebar -->
      <div class="col-md-3 sidebar">
        <h2>
          <%= user.name %>
        </h2>
        <a href="/userProfile" class="nav-link">My Profile</a>
        <a href="/address" class="nav-link">Address</a>
        <a href="/my-order" class="nav-link">Orders</a>
        <a href="/wallet" class="nav-link">Wallet</a>
      </div>

      <!-- Main Content -->
      <div class="col-md-9">
        <div class="mt-5 px-4">
          <!-- <h2 class="mb-4 text-center fw-bold">My Orders</h2> -->
           <h2 class="text-center mb-5 fw-light" style="font-family: 'Cinzel', serif; letter-spacing: 4px;">My Orders</h2>

          <!-- Search -->
          <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
            <div class="search-container position-relative" style="width: 500px;">
              <input type="text" class="form-control" id="searchInput" placeholder="Search by Order Id..."
                value="<%= search || '' %>">
              <span class="search-clear" id="clearSearch" style="display:none;">&times;</span>
            </div>
          </div>

          <!-- Example Order Card -->
          <% if(orders && orders.length> 0) { %>
            <% orders.forEach(order=> { %>
              <div class="card order-card mb-4">
                <div class="order-header d-flex justify-content-between align-items-center p-3">
                  <span>Order ID: <strong>
                      <%= order.orderId %>
                    </strong></span>
                  <span>
                    <%= order.status %>
                  </span>
                </div>
                <div class="card-body">
                  <p><strong>Order Placed:</strong>
                    <%= order.invoiceDate.toLocaleDateString('en-GB', { day: 'numeric' , month: 'short' ,
                      year: 'numeric' }) %>
                  </p>
                  <p><strong>Total Amount:</strong> ₹<%= order.finalAmount %>
                  </p>
                  <!-- <p><strong>Coupon Discount Amount:</strong> ₹<%= order.discountAmount %>
                  </p>
                  <p><strong>Offer Amount:</strong> ₹<%= order.offerAppliedAmount  %></p> -->
                  <p><strong>Delivery Charge:</strong> ₹<%= order.deliveryCharge %>
                  </p>
                  <p><strong>Payment Method:</strong>
                    <%= order.paymentMethod==='cod' ? 'Cash on Delivery' : order.paymentMethod.toUpperCase() %>
                  </p>
                  <p><strong>Payment Status:</strong>
                    <%= order.paymentStatus %>
                  </p>

                  <!-- Products -->
                  <div class="products-list mb-3">
                    <% order.items.forEach(item=> { %>
                      <div class="d-flex align-items-center mb-2 product-item
                      <%= item.itemStatus === 'Cancelled' ? 'cancelled-product' : '' %>">
                        <% if (item.image) { %>
                          <img src="/<%= item.image %>" alt="<%= item.productName %>"
                            style="width: 100px; height: 120px; object-fit: cover; margin-right: 10px;">
                          <% } else { %>
                            <div style="width:100px; height:120px; background:#ccc; margin-right:10px;"></div>
                            <% } %>
                              <div>
                                <p class="mb-0">
                                  <strong>
                                    <%= item.productName %>
                                  </strong>
                                </p>
                                <p class="mb-0">Qty: <%= item.quantity %>
                                </p>
                                <p class="mb-0">Price: ₹<%= item.price %>
                                </p>
                                <!-- <p class="mb-0">Final Price: ₹<%=item.finalPrice%></p> -->
                                <% if (item.itemStatus==='Cancelled' ) { %>
                                  <span class="badge bg-secondary mt-1">Cancelled</span>
                                  <% } %>

                                    <% if (item.itemStatus==='Pending' && order.status==='Pending' ) { %>
                                      <a href="#" class="text-danger cancel-product"
                                        style="cursor: pointer; text-decoration: none;"
                                        data-order="<%= order.orderId %>" data-product="<%= item.productId %>">
                                        Cancel Product
                                      </a>
                                      <% } %>
                              </div>
                      </div>
                      <% }) %>
                  </div>

                  <% const hasActiveItems=order.items.some( item=> item.itemStatus !== 'Cancelled' ) %>
                    <%const isCancellable=order.status==='Pending' ;%>
                      <!-- Actions -->
                      <div class="order-actions d-flex gap-2">
                        <%if(isCancellable){%>
                          <button class="btn btn-danger btn-sm cancel-order" data-bs-toggle="modal"
                            data-bs-target="#cancelOrderModal" data-order="<%= order.orderId %>">Cancel Order</button>
                          <%}%>
                          <%if(order.paymentStatus === 'Failed' && order.paymentMethod !== 'cod' && order.status !== 'Cancelled'){%>
                            <button class="btn btn-warning btn-sm retry-payment" data-order-id="<%= order.orderId %>">Retry Payment</button>
                            <%}%>
                            <a href="/view-order-details/<%= order.orderId %>" class="btn btn-primary btn-sm">View Details</a>
                            <a href="/invoice/<%= order.orderId %>" class="btn btn-success btn-sm">Download Invoice</a>
                      </div>
                </div>
              </div>

              <!-- Cancel Product Modal -->
              <div class="modal fade" id="cancelProductModal" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog">
                  <form class="modal-content" id="cancelProductForm">
                    <!-- Hidden inputs for orderId and productId  -->
                    <input type="hidden" name="orderId" id="cancelOrderId">
                    <input type="hidden" name="productId" id="cancelProductId">

                    <div class="modal-header">
                      <h5 class="modal-title">Cancel Product</h5>
                      <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>

                    <div class="modal-body">
                      <label class="form-label">Reason</label>
                      <div>
                        <div class="form-check">
                          <input class="form-check-input cancel-reason" type="radio" name="reasonOption"
                            value="Ordered by mistake" id="reason1">
                          <label class="form-check-label" for="reason1">Ordered by mistake</label>
                        </div>
                        <div class="form-check">
                          <input class="form-check-input cancel-reason" type="radio" name="reasonOption"
                            value="Found a better price" id="reason2">
                          <label class="form-check-label" for="reason2">Found a better price</label>
                        </div>
                        <div class="form-check">
                          <input class="form-check-input cancel-reason" type="radio" name="reasonOption" value="Other"
                            id="reasonOther">
                          <label class="form-check-label" for="reasonOther">Other</label>
                        </div>
                      </div>

                      <textarea class="form-control mt-2" name="reason" id="otherReason" rows="3"
                        placeholder="Enter your reason..." style="display:none;"></textarea>
                    </div>

                    <div class="modal-footer">
                      <button type="submit" class="btn btn-danger">Confirm Cancel</button>
                    </div>
                  </form>
                </div>
              </div>



              <!-- Cancel Order Modal  -->
              <div class="modal fade" id="cancelOrderModal" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog">
                  <form class="modal-content" id="cancelOrderFormUnique">
                    <!-- Hidden input for orderId  -->
                    <input type="hidden" name="orderId" id="orderIdInput">

                    <div class="modal-header">
                      <h5 class="modal-title">Cancel Order</h5>
                      <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>

                    <div class="modal-body">
                      <label class="form-label">Select Reason</label>
                      <div>
                        <div class="form-check">
                          <input class="form-check-input order-cancel-reason" type="radio" name="orderReasonOption"
                            value="Ordered by mistake" id="orderReason1">
                          <label class="form-check-label" for="orderReason1">Ordered by mistake</label>
                        </div>
                        <div class="form-check">
                          <input class="form-check-input order-cancel-reason" type="radio" name="orderReasonOption"
                            value="Found a better price" id="orderReason2">
                          <label class="form-check-label" for="orderReason2">Found a better price</label>
                        </div>
                        <div class="form-check">
                          <input class="form-check-input order-cancel-reason" type="radio" name="orderReasonOption"
                            value="Other" id="orderReasonOther">
                          <label class="form-check-label" for="orderReasonOther">Other</label>
                        </div>
                      </div>

                      <textarea class="form-control mt-2" name="reason" id="orderOtherReason" rows="3"
                        placeholder="Enter your reason..." style="display:none;"></textarea>
                    </div>

                    <div class="modal-footer">
                      <button type="submit" class="btn btn-danger">Confirm Cancel</button>
                    </div>
                  </form>
                </div>
              </div>
              <% }) %>
                <% } else { %>
                  <p class="text-center mt-5" style="color: #555;">No orders placed yet.</p>
                  <% } %>
        </div>

        <div class="container pagination-container">
          <nav aria-label="Page Navigation">
            <ul class="pagination justify-content-center mb-20">
              <% for(let i=1; i <=totalPages; i++) { %>
                <li class="page-item <%=(i === currentPage) ? 'active' : '' %>">
                  <a class="page-link" href="?page=<%= i %>">
                    <%= i %>
                  </a>
                </li>
                <% } %>
            </ul>
          </nav>
        </div>

      </div>
    </div>
  </div>






  <%-include("../../views/partials/user/footer")%>



    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/your-order-modal.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>


    <script>



const currentPath = window.location.pathname;
 document.querySelectorAll('.sidebar .nav-link').forEach(link => {
   if(link.getAttribute('href') === currentPath){
     link.classList.add('active');
   }
 });


      const searchInput = document.getElementById('searchInput');
      const clearBtn = document.getElementById('clearSearch');

      searchInput.addEventListener('input', () => {
        clearBtn.style.display = searchInput.value ? 'block' : 'none';
      });

      searchInput.addEventListener('keypress', function (e) {
        if (e.key === 'Enter') {
          const query = searchInput.value.trim();
          window.location.href = `/my-order?search=${encodeURIComponent(query)}`;
        }
      });

      clearBtn.addEventListener('click', () => {
        searchInput.value = '';
        clearBtn.style.display = 'none';
        window.location.href = '/my-order';
      });

      if (searchInput.value) {
        clearBtn.style.display = 'block';
      }




      document.addEventListener('DOMContentLoaded', () => {

        const retryBtns = document.querySelectorAll(".retry-payment");
  
  // Check if there are any retry buttons
  if (retryBtns.length === 0) return;

  // Add event listener to each button
  retryBtns.forEach(btn => {
    btn.addEventListener("click", async function (e) {
      e.preventDefault(); // Prevent default if it's a button in a form or link
      
      const orderId = this.dataset.orderId;
      console.log("Retry payment clicked for order:", orderId); // Debug log

      if (!orderId) {
        Swal.fire("Error", "Order ID is missing", "error");
        return;
      }

      const originalText = this.innerHTML;
      this.disabled = true;
      this.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Processing...';

      try {
        // 1️⃣ Create Razorpay order again
        const res = await fetch(`/retry-payment/${orderId}`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          credentials: "same-origin",
        });

        const data = await res.json();
        console.log("Retry response:", data); // Debug log

        if (!data.success) {
          Swal.fire("Retry Failed", data.message || "Unable to retry payment", "error");
          this.disabled = false;
          this.innerHTML = originalText;
          return;
        }

        // 2️⃣ Razorpay options
        const options = {
          key: "<%= razorpayKeyId %>",
          amount: data.razorpayOrder.amount,
          currency: data.razorpayOrder.currency,
          order_id: data.razorpayOrder.id,
          name: "The Untold Stories",
          description: "Retry Order Payment",
          prefill: {
            name: "<%= user.name %>",
            email: "<%= user.email %>",
            contact: "<%= user.phone || '' %>",
          },
          handler: async function (response) {
            console.log("Payment response:", response); // Debug log
            
            try {
              const verifyRes = await fetch("/verify-payment", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                  razorpay_order_id: response.razorpay_order_id,
                  razorpay_payment_id: response.razorpay_payment_id,
                  razorpay_signature: response.razorpay_signature,
                  orderId: orderId,
                }),
              });

              const verifyData = await verifyRes.json();
              console.log("Verification response:", verifyData); // Debug log

              if (verifyData.success) {
                window.location.href = "/order-success";
              } else {
                window.location.href = `/order-failed/${orderId}`;
              }
            } catch (err) {
              console.error("Verify error:", err);
              window.location.href = `/order-failed/${orderId}`;
            }
          },
          modal: {
            ondismiss: function () {
              window.location.href = `/order-failed/${orderId}`;
            },
          },
          theme: {
            color: "#3399cc",
          },
        };

        // Re-enable button in case Razorpay modal is cancelled
        this.disabled = false;
        this.innerHTML = originalText;

        const rzp = new Razorpay(options);

        rzp.on("payment.failed", function (response) {
          console.error("Payment failed:", response);
          window.location.href = `/order-failed/${orderId}`;
        });

        rzp.open();
      } catch (err) {
        console.error("Retry payment error:", err);
        Swal.fire("Error", "Something went wrong. Please try again.", "error");
        this.disabled = false;
        this.innerHTML = originalText;
      }
    });
  });












        const cancelLinks = document.querySelectorAll('.cancel-product');
        const cancelOrderIdInput = document.getElementById('cancelOrderId');
        const cancelProductIdInput = document.getElementById('cancelProductId');
        const cancelForm = document.getElementById('cancelProductForm');
        const cancelModal = new bootstrap.Modal(document.getElementById('cancelProductModal'));

        cancelLinks.forEach(link => {
          link.addEventListener('click', (e) => {
            if (link.classList.contains('disabled-link')) return;
            e.preventDefault();
            const orderId = link.dataset.order;
            const productId = link.dataset.product;

            cancelOrderIdInput.value = orderId;
            cancelProductIdInput.value = productId;

            cancelForm.action = `/cancel-product/${orderId}/${productId}`;

            cancelModal.show();
          });
        });

        const reasonRadios = document.querySelectorAll('.cancel-reason');
        const otherReason = document.getElementById('otherReason');

        reasonRadios.forEach(radio => {
          radio.addEventListener('change', () => {
            if (radio.value === 'Other' && radio.checked) {
              otherReason.style.display = 'block';
              otherReason.required = true;
            } else {
              otherReason.style.display = 'none';
              otherReason.required = false;
            }
          });
        });


        cancelForm.addEventListener('submit', async (e) => {
          e.preventDefault();

          const orderId = cancelOrderIdInput.value;
          const productId = cancelProductIdInput.value;
          const reason = document.querySelector('input[name="reasonOption"]:checked')?.value === 'Other'
            ? otherReason.value
            : document.querySelector('input[name="reasonOption"]:checked')?.value;

          try {
            const res = await fetch(`/cancel-product/${orderId}/${productId}`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ reason })
            });

            const data = await res.json();

            if (data.success) {
              Swal.fire({
                icon: 'success',
                title: 'Cancelled!',
                text: data.message,
                confirmButtonText: 'OK'
              }).then(() => {
                cancelModal.hide();
                location.reload();
              });
            } else {
              Swal.fire({
                icon: 'error',
                title: 'Oops...',
                text: data.message
              });
            }
          } catch (err) {
            console.error(err);
            Swal.fire({
              icon: 'error',
              title: 'Error',
              text: 'Something went wrong'
            });
          }
        });

      });





      const cancelOrderLinks = document.querySelectorAll('.cancel-order')
      const orderIdInput = document.getElementById('orderIdInput');
      const cancelOrderForm = document.getElementById('cancelOrderFormUnique');
      const cancelOrderModal = new bootstrap.Modal(document.getElementById('cancelOrderModal'));

      cancelOrderLinks.forEach(link => {
        link.addEventListener('click', (e) => {
          if (link.disabled) return;
          e.preventDefault();
          const orderId = link.dataset.order;

          orderIdInput.value = orderId;

          cancelOrderForm.action = `/cancel-order/${orderId}`;

          cancelOrderModal.show();
        });
      });

      const orderReasonRadios = document.querySelectorAll('.order-cancel-reason');
      const orderOtherReason = document.getElementById('orderOtherReason');

      orderReasonRadios.forEach(radio => {
        radio.addEventListener('change', () => {
          if (radio.value === 'Other' && radio.checked) {
            orderOtherReason.style.display = 'block';
            orderOtherReason.required = true;
          } else {
            orderOtherReason.style.display = 'none';
            orderOtherReason.required = false;
          }
        });
      });



      cancelOrderForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const orderId = orderIdInput.value;
        const reason = document.querySelector('input[name="orderReasonOption"]:checked')?.value === 'Other'
          ? orderOtherReason.value
          : document.querySelector('input[name="orderReasonOption"]:checked')?.value;

        try {
          const res = await fetch(`/cancel-order/${orderId}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ reason })
          });

          const data = await res.json();

          if (data.success) {
            Swal.fire({
              icon: 'success',
              title: 'Cancelled!',
              text: data.message,
              confirmButtonText: 'OK'
            }).then(() => {
              cancelOrderModal.hide();
              location.reload();
            });
          } else {
            Swal.fire({
              icon: 'error',
              title: 'Oops...',
              text: data.message
            });
          }
        } catch (err) {
          console.error(err);
          Swal.fire({
            icon: 'error',
            title: 'Error',
            text: 'Something went wrong'
          });
        }
      });























      



    </script>