    <style>

/* first part */
/* Reset */
/* Reset */
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* Body */
body {
  font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
  background-color: #fff;
  color: #333;
}

/* Header Wrapper */
#header-wrap {
  background-color: #222;
  color: #fff;
  padding: 10px 20px;
  position: relative;
}

/* Container for top content */
.top-content .container-fluid {
  max-width: 1200px;
  margin: 0 auto;
}

/* Flex row for header */
.top-content .row {
  display: flex;
  justify-content: space-between; /* Push left and right apart */
  align-items: center;
  width: 100%;
}

/* Left side: Website name */
.top-content .col-md-6:first-child {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  padding-left: 0;
}

.top-content .col-md-6:first-child p {
  font-size: 1.2rem;
  font-weight: bold;
  margin-bottom: 0; /* remove extra margin */
  color: #fff;
}

/* Right side: Navigation links & elements */
.top-content .col-md-6:last-child {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 30px; /* space between links */
  padding-right: 0;
  flex-wrap: wrap;
}

/* Links styling */
.right-element a {
  display: inline-flex;
  align-items: center;
  color: #fff;
  text-decoration: none;
  font-weight: 500;
  transition: color 0.3s ease;
  white-space: nowrap; /* prevent wrap */
}

.right-element a:hover {
  color: #fca311; /* accent on hover */
}

/* Icon spacing inside links */
.right-element a i.icon {
  margin-right: 6px;
}

/* Search bar styling */
.search-bar {
  position: relative;
  display: inline-block;
}

.search-button {
  color: #fff;
  font-size: 1.1rem;
  cursor: pointer;
  margin-right: 10px;
}

.search-box {
  display: none;
  position: absolute;
  top: 100%;
  right: 0;
  margin-top: 5px;
  z-index: 10;
}

.search-box input.search-field {
  padding: 6px 8px;
  border-radius: 4px;
  border: none;
  width: 180px;
  font-size: 1rem;
}

/* Show search box on hover/focus */
.search-bar:hover .search-box,
.search-button:focus + .search-box {
  display: block;
}

/* Hamburger menu for mobile */
.hamburger {
  display: none; /* Hidden on desktop */
  cursor: pointer;
  position: absolute;
  top: 15px;
  right: 20px;
  z-index: 100;
}

.hamburger .bar {
  width: 25px;
  height: 3px;
  margin: 5px 0;
  background-color: #fff;
  border-radius: 2px;
}

/* Billboard Section */
#billboard {
  padding: 40px 20px;
  background-color: #f5f5f5;
}

#billboard .container {
  max-width: 1200px;
  margin: 0 auto;
}

.slider-item {
  display:flex !important;
  flex-direction: row !important;
  align-items: center;
  justify-content: space-between; 
  gap: 40px;
}


.banner-content {
  flex: 1;
   text-align: left; /* force left align */
}

.banner-title {
  font-size: 2rem;
  margin-bottom: 12px;
  color: #222;
}

.banner-content p {
  font-size: 1rem;
  line-height: 1.5;
  margin-bottom: 16px;
  color: #555;
}

.btn-wrap a.btn {
  display: inline-block;
  padding: 8px 16px;
  border: 2px solid #fca311;
  color: #fca311;
  text-decoration: none;
  border-radius: 25px;
  font-weight: 600;
  transition: background-color 0.3s ease, color 0.3s ease;
}

.btn-wrap a.btn:hover {
  background-color: #fca311;
  color: #fff;
}

/* Banner Image */
.banner-image {
  flex-shrink: 0;
  width: 400px;
  height: auto;
  object-fit: cover;

}

/* Slick arrows */
.slick-arrow {
  background: none;
  border: none;
  font-size: 2rem;
  color: #222;
  cursor: pointer;
  padding: 0 10px;
  transition: color 0.3s ease;
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 10;
}

.prev {
  left: 15px;
}

.next {
  right: 15px;
}

.slick-arrow:hover {
  color: #fca311;
}

/* Responsive */
@media (max-width: 768px) {
  /* Hide some links, show hamburger */
  .right-element a:not(.user-account):not(.cart) {
    display: none;
  }

  .hamburger {
    display: block;
  }

  /* Stack slider content vertically */
  .slider-item {
    flex-direction: column;
    text-align: center;
  }

  .banner-content {
    padding-bottom: 20px;
  }

  .banner-image {
    width: 100%;
    max-width: 300px;
    margin: 0 auto;
  }

  .slick-arrow {
    font-size: 1.5rem;
  }
}



/* Flex container for header */
.header-flex {
  display: flex;
  justify-content: space-between;
  align-items: center;
  max-width: 1200px;
  margin: 0 auto;
  padding: 10px 0;
}

/* Website name on the left */
.site-title {
  font-size: 1.5rem;
  font-weight: bold;
  color: #fff;
  margin: 0; /* Remove default p margin */
}

/* Right side links styling */
.right-element a {
  color: #fff;
  margin-left: 25px; /* spacing between links */
  text-decoration: none;
  font-weight: 500;
  transition: color 0.3s ease;
  display: inline-flex;
  align-items: center;
}

.right-element a:hover {
  color: #fca311;
}

/* Icons inside links */
.right-element a i.icon {
  margin-right: 6px;
}

/* Search bar */
.search-bar {
  display: inline-block;
  position: relative;
  margin-left: 25px; /* spacing from last link */
}

.search-button {
  color: #fff;
  font-size: 1.1rem;
  cursor: pointer;
}

.search-box {
  display: none;
  position: absolute;
  top: 100%;
  right: 0;
  margin-top: 5px;
}

.search-box input.search-field {
  padding: 6px 8px;
  border-radius: 4px;
  border: none;
  width: 180px;
  font-size: 1rem;
}

.search-bar:hover .search-box,
.search-button:focus + .search-box {
  display: block;
}

/* Header background and color */
#header-wrap {
  background-color: #222;
  color: #fff;
  position: relative;
}

/* Responsive adjustments */
@media (max-width: 768px) {
  .header-flex {
    flex-wrap: wrap;
    justify-content: space-between;
  }

  .right-element a:not(.user-account):not(.cart) {
    display: none;
  }

  .search-bar {
    margin-left: 0;
  }
}













/* 
second part */
/* Featured Books Section */
#featured-books {
  background-color: #fff;
  padding-top: 3rem;
  padding-bottom: 3rem;
  margin-top: 3rem;
  margin-bottom: 3rem;
}

#featured-books .section-header {
  margin-bottom: 40px;
  text-align: center;
}

#featured-books .title span {
  display: inline-block;
  font-weight: 600;
  font-size: 1rem;
  color: #fca311;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  margin-bottom: 8px;
}

#featured-books .section-title {
  font-size: 2.5rem;
  font-weight: 700;
  color: #222;
}

/* Product list grid */
#featured-books .product-list .row {
  gap: 20px;
}

/* Product item */
.product-item {
  background-color: #fafafa;
  border-radius: 10px;
  padding: 15px;
  box-shadow: 0 2px 6px rgba(0,0,0,0.1);
  transition: box-shadow 0.3s ease;
}

.product-item:hover {
  box-shadow: 0 6px 15px rgba(0,0,0,0.15);
}

/* Figure and Image */
.product-style {
  position: relative;
  overflow: hidden;
  border-radius: 10px;
  margin-bottom: 15px;
}

.product-style img.product-item {
  width: 100%;
  height: auto;
  display: block;
  border-radius: 10px;
  transition: transform 0.3s ease;
}

.product-style:hover img.product-item {
  transform: scale(1.05);
}

/* Add to Cart Button */
.add-to-cart {
  position: absolute;
  bottom: 10px;
  left: 50%;
  transform: translateX(-50%);
  background-color: #fca311;
  color: #fff;
  border: none;
  padding: 10px 20px;
  font-weight: 600;
  border-radius: 25px;
  cursor: pointer;
  opacity: 0;
  transition: opacity 0.3s ease;
}



.product-style:hover .add-to-cart {
  opacity: 1;
}

/* Figcaption */
figcaption h3 {
  font-size: 1.2rem;
  font-weight: 700;
  color: #222;
  margin-bottom: 6px;
}

figcaption span {
  display: block;
  font-size: 1rem;
  color: #777;
  margin-bottom: 8px;
}

figcaption .item-price {
  font-size: 1.1rem;
  font-weight: 700;
  color: #fca311;
}

/* Button wrap for View all */
#featured-books .btn-wrap.align-right {
  text-align: right;
  margin-top: 30px;
}

.btn-accent-arrow {
  background-color: transparent;
  border: 2px solid #fca311;
  color: #fca311;
  padding: 10px 20px;
  border-radius: 25px;
  font-weight: 600;
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  transition: all 0.3s ease;
}

.btn-accent-arrow:hover {
  background-color: #fca311;
  color: #fff;
}

/* Icon next to text */
.btn-accent-arrow .icon-ns-arrow-right {
  font-size: 1.2rem;
}







/* third part */
/* Best Selling Book Section */
#best-selling {
  position: relative;
  background-color: #f9f9f9;
  padding: 5rem 0;
  overflow: hidden;
}

#best-selling .corner-pattern-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: url('images/leaf-pattern.png') repeat;
  opacity: 0.1;
  pointer-events: none;
  z-index: 1;
}

#best-selling .container {
  position: relative;
  z-index: 2;
}

#best-selling .products-thumb {
  margin-bottom: 2rem;
}

#best-selling .products-thumb img.single-image {
  width: 100%;
