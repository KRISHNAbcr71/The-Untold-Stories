




<!DOCTYPE html>
<html lang="en">

<head>
  <title>Home Page</title>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.css" />
  <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick-theme.css" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/easyzoom@2.5.0/css/easyzoom.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500&family=Montserrat:wght@300;400;500&family=Playfair+Display:ital,wght@0,500;1,500&display=swap" rel="stylesheet">

  <style>
    /* --- Base Header Layout --- */
    #main-header {
      padding: 12px 0;
      position: sticky;
      top: 0;
      z-index: 1000;
      background-color: #5c492c;
      border-bottom: 1px solid #28231f;
    }

    .header-content {
      display: flex;
      justify-content: space-between;
      align-items: center;
      width: 100%;
    }

    /* --- Three-Column Logic --- */
    .nav-left {
      flex: 1; /* Takes equal space on the left */
      display: flex;
      gap: 30px;
    }

    .logo-center {
      flex: 0 0 auto; /* Keeps logo centered between the two flex-1 containers */
      text-align: center;
    }

    .right-nav {
      flex: 1; /* Takes equal space on the right */
      display: flex;
      justify-content: flex-end;
      align-items: center;
      gap: 15px;
    }

    /* --- Typography & Elements --- */
    .nav-link-aesthetic {
      font-family: 'Montserrat', sans-serif;
      color: #fff;
      text-decoration: none;
      text-transform: uppercase;
      font-size: 0.75rem;
      letter-spacing: 0.15em;
      opacity: 0.8;
      transition: 0.3s;
    }

    .nav-link-aesthetic:hover {
      opacity: 1;
      color: #d4a373;
    }

    .editorial-logo {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-decoration: none;
      line-height: 1;
      transition: transform 0.3s ease;
    }

    .editorial-logo:hover { transform: translateY(-2px); }

    .editorial-logo .top-line {
      font-family: 'Montserrat', sans-serif;
      font-size: 0.65rem;
      letter-spacing: 0.4em;
      text-transform: uppercase;
      color: #d4a373;
      margin-bottom: 2px;
      font-weight: 500;
    }

    .editorial-logo .bottom-line {
      font-family: 'Playfair Display', serif;
      font-size: 1.8rem;
      font-weight: 500;
      font-style: italic;
      letter-spacing: -0.02em;
      color: #ffffff;
    }

    /* --- User Dropdown --- */
    .user-dropdown { position: relative; }

    .user-dropdown::after {
      content: "";
      position: absolute;
      top: 100%;
      left: 0;
      width: 100%;
      height: 20px; /* Invisible bridge */
    }

    .dropdown-menu-custom {
      position: absolute;
      right: 0;
      top: 100%;
      margin-top: 15px;
      background-color: #1a1a1a;
      border: 1px solid #333;
      min-width: 160px;
      display: flex;
      flex-direction: column;
      padding: 8px 0;
      box-shadow: 0 10px 30px rgba(0,0,0,0.5);
      opacity: 0;
      visibility: hidden;
      transform: translateY(10px);
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .user-dropdown:hover .dropdown-menu-custom {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }

    .dropdown-item-custom {
      color: #bbb;
      padding: 12px 20px;
      text-decoration: none;
      font-size: 0.8rem;
      font-family: 'Montserrat', sans-serif;
      text-transform: uppercase;
      letter-spacing: 1px;
      transition: all 0.3s ease;
      border-left: 0 solid #d4a373;
      display: block;
    }

    .dropdown-item-custom:hover {
      background-color: #252525;
      color: #fff !important;
      padding-left: 25px;
      border-left: 4px solid #d4a373;
    }

    /* --- Responsive Hide --- */
    @media (max-width: 768px) {
      .nav-left { display: none; }
    }
  </style>
</head>

<body>
  <header id="main-header">
    <div class="container header-content">

      <nav class="nav-left d-none d-md-flex">
        <a href="/" class="nav-link-aesthetic">Home</a>
        <a href="/shop" class="nav-link-aesthetic">Shop</a>
      </nav>

      <div class="logo-center">
        <a href="#" class="editorial-logo" onclick="scrollToTop()">
          <span class="top-line">The Untold</span>
          <span class="bottom-line">Stories</span>
        </a>
      </div>

      <div class="right-nav">
        <a href="/cart" class="icon-link position-relative text-white me-2">
          <i class="fas fa-shopping-cart"></i>
          <span class="badge-count cart-count">0</span>
        </a>

        <a href="/wishlist" class="icon-link position-relative text-white me-3">
          <i class="fas fa-heart"></i>
          <span class="badge-count wishlist-count">0</span>
        </a>

        <% if (typeof user !=='undefined' && user) { %>
          <div class="user-dropdown">
            <a href="#" class="nav-link-aesthetic" style="color: #d4a373;">
              <%= user.name %> <i class="fas fa-caret-down ms-1"></i>
            </a>
            <div class="dropdown-menu-custom">
              <a href="/userProfile" class="dropdown-item-custom">Profile</a>
              <a href="/logout" class="dropdown-item-custom">Logout</a>
            </div>
          </div>
        <% } else { %>
          <a href="/login" class="nav-link-aesthetic me-2">Login</a>
          <a href="/signup" class="btn btn-sm" style="background-color: #d4a373; color: white; font-size: 0.7rem; letter-spacing: 1px;">SIGN UP</a>
        <% } %>
      </div>

    </div>
  </header>

  <script src="https://cdn.jsdelivr.net/npm/easyzoom@2.5.0/dist/easyzoom.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.all.min.js"></script>

  <script>
    function scrollToTop() {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    async function updateCounts() {
      try {
        const [cartRes, wishRes] = await Promise.all([
          fetch('/cart-count'),
          fetch('/wishlist-count')
        ]);
        
        const cartData = await cartRes.json();
        const wishData = await wishRes.json();

        const cartEl = document.querySelector('.cart-count');
        const wishEl = document.querySelector('.wishlist-count');

        if (cartEl) cartEl.textContent = cartData.count;
        if (wishEl) wishEl.textContent = wishData.count;
      } catch (error) {
        console.error('Error fetching counts:', error);
      }
    }

    updateCounts();
    setInterval(updateCounts, 10000);
  </script>
</body>
</html>