}

#best-selling .item-price {
  font-size: 1.5rem;
  font-weight: 700;
  color: #fca311;
  margin-bottom: 2rem;
}

#best-selling .btn-wrap a.btn-accent-arrow {
  background-color: #fca311;
  color: white;
  padding: 12px 30px;
  border-radius: 25px;
  font-weight: 600;
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  transition: background-color 0.3s ease;
}

#best-selling .btn-wrap a.btn-accent-arrow:hover {
  background-color: #d18e0b;
}

#best-selling .btn-wrap a .icon-ns-arrow-right {
  font-size: 1.2rem;
}

/* Responsive tweaks */
@media (max-width: 768px) {
  #best-selling .row > .col-md-6 {
    margin-bottom: 2rem;
  }
}








/* fourth part */
/* Container and Section */
#popular-books {
  background-color: #f8f9fa;
  padding: 40px 0;
  font-family: Arial, sans-serif;
  color: #333;
}

.container {
  width: 90%;
  max-width: 1200px;
  margin: 0 auto;
}

/* Section Header */
.section-header {
  text-align: center;
  margin-bottom: 30px;
}

.section-header .title span {
  color: #ff6f61;
  font-weight: bold;
  letter-spacing: 2px;
  text-transform: uppercase;
  font-size: 14px;
}

.section-header h2.section-title {
  font-size: 36px;
  margin-top: 10px;
  font-weight: 700;
}

/* Tabs */
.tabs {
  list-style: none;
  display: flex;
  justify-content: center;
  gap: 15px;
  padding: 0;
  margin-bottom: 40px;
  cursor: pointer;
}

.tabs li {
  padding: 10px 25px;
  border: 2px solid #ff6f61;
  border-radius: 30px;
  color: #ff6f61;
  font-weight: 600;
  transition: all 0.3s ease;
  user-select: none;
}

.tabs li.active,
.tabs li:hover {
  background-color: #ff6f61;
  color: white;
  box-shadow: 0 4px 10px rgba(255, 111, 97, 0.4);
}

/* Tab Content */
.tab-content > div {
  display: none;
}

.tab-content > div.active {
  display: block;
}

/* Product Grid */
.row {
  display: flex;
  flex-wrap: wrap;
  gap: 20px;
  justify-content: center;
}

.col-md-3 {
  flex: 1 1 22%;
  max-width: 22%;
  box-sizing: border-box;
}

@media (max-width: 992px) {
  .col-md-3 {
    flex: 1 1 45%;
    max-width: 45%;
  }
}

@media (max-width: 576px) {
  .col-md-3 {
    flex: 1 1 100%;
    max-width: 100%;
  }
}

/* Product Item */
.product-item {
