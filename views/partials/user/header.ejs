/* sixth part */
/* Footer general styles */
#footer {
  background-color: #222; /* dark background */
  color: #eee; /* light text */
  padding: 40px 20px;
  font-family: Arial, sans-serif;
  font-size: 14px;
}

/* Container inside footer */
#footer .container {
  max-width: 1200px;
  margin: 0 auto;
}

/* Row using flexbox */
#footer .row {
  display: flex;
  flex-wrap: nowrap; /* prevent wrapping */
  gap: 20px;
  justify-content: space-between; /* evenly distribute columns */
}

/* Columns - flexible widths */
#footer .col-md-4 {
  flex: 1 1 38%; /* grow, shrink, basis */
  min-width: 250px; /* prevent too small */
  box-sizing: border-box;
}

#footer .col-md-2 {
  flex: 1 1 14%; /* grow, shrink, basis */
  min-width: 150px;
  box-sizing: border-box;
}

/* Responsive: stack columns on smaller screens */
@media (max-width: 768px) {
  #footer .row {
    flex-wrap: wrap; /* allow wrapping */
  }
  #footer .col-md-4,
  #footer .col-md-2 {
    flex: 0 0 100%;
    max-width: 100%;
    min-width: auto;
    margin-bottom: 20px;
  }
}

/* Footer headings */
#footer h3,
#footer h5 {
  margin-top: 0;
  margin-bottom: 15px;
  font-weight: bold;
  color: #fff;
}

/* Paragraph inside company brand */
#footer .company-brand p {
  line-height: 1.6;
  color: #bbb;
}

/* Menu list styling */
#footer .footer-menu ul.menu-list {
  list-style: none;
  padding: 0;
  margin: 0;
}

#footer .footer-menu ul.menu-list li.menu-item {
  margin-bottom: 10px;
}

#footer .footer-menu ul.menu-list li.menu-item a {
  color: #bbb;
  text-decoration: none;
  transition: color 0.3s ease;
}

#footer .footer-menu ul.menu-list li.menu-item a:hover {
  color: #f39c12; /* highlight color on hover */
  text-decoration: underline;
}




/* seventh part */
/* Footer bottom general styles */
#footer-bottom {
  background-color: #111; /* darker background */
  color: #ccc;
  padding: 20px 0;
  font-size: 14px;
  font-family: Arial, sans-serif;
}

/* Container max width */
#footer-bottom .container {
  max-width: 1200px;
  margin: 0 auto;
}

/* Outer row as flexbox */
#footer-bottom .row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
}

/* Full width column */
#footer-bottom .col-md-12 {
  width: 100%;
  box-sizing: border-box;
}

/* Inner row (for copyright and social links) */
#footer-bottom .copyright .row {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  align-items: center;
  gap: 10px;
}

/* Left side: copyright */
#footer-bottom .copyright .col-md-6 {
  flex: 1 1 50%;
  box-sizing: border-box;
}

/* Right side: social links */
#footer-bottom .social-links {
  text-align: right;
}

/* Social icons list */
#footer-bottom .social-links ul {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  gap: 15px;
