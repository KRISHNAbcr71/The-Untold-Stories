  padding: 8px 15px;
  border-radius: 20px;
  font-weight: bold;
  cursor: pointer;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.product-style:hover .add-to-cart {
  opacity: 1;
}

/* Product Text */
figcaption {
  padding: 15px 20px;
  text-align: center;
}

figcaption h3 {
  font-size: 18px;
  margin: 10px 0 5px 0;
  font-weight: 600;
  color: #222;
}

figcaption span {
  font-size: 14px;
  color: #888;
  display: block;
  margin-bottom: 10px;
}

.item-price {
  font-size: 16px;
  font-weight: 700;
  color: #ff6f61;
}





