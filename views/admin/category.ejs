<%-include("../../views/partials/admin/header")%>
    <link rel="stylesheet" href="/css/category.css">


    <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-3">
        <h2 class="fw-bold mb-0 ps-4">🗂️ Category</h2>
        <div class="search-container position-relative">
            <input type="text" class="form-control" id="searchInput" placeholder="Search categories..."
                value="<%= search || '' %>">
            <span class="search-clear" id="clearSearch" style="display:none;">&times;</span>
        </div>
    </div>

    <!-- If no results -->
    <% if (noResults) { %>
        <div class="text-center text-danger mb-3">No results found</div>
        <% } %>

            <!-- <div class="d-flex" style="gap: 10px;">
                <a href="/admin/addCategory" class="btn btn-secondary add-cat" style="width: 200px;">Add Category</a>
                <a href="/admin/trash-category" class="btn btn-secondary add-cat" style="width: 200px;">Trash</a>
            </div> -->
            <div class="d-flex mb-4 ps-4" style="gap: 12px;">
  <a href="/admin/addCategory" class="btn add-cat-btn">
    <span class="icon">➕</span>
    Add Category
  </a>
</div>




            <div class="table-wrapper">

                <div class="table-responsive container-fluid">
                    <table class="table align-middle admin-table">
                        <thead class="table-secondary">
                            <tr>
                                <th>Number</th>
                                <th>Name</th>
                                <th>Description</th>
                                <th>Action</th>
                                <th>Edit</th>
                                <th>Delete</th>
                            </tr>
                        </thead>
                        <tbody>
                            <%cat.forEach((category,index)=>{%>
                                <tr>
                                    <td>
                                        <% if (search && search.trim() !=="" ) { %>
                                            <%= category.serialNumber %>
                                                <% } else { %>
                                                    <%= (currentPage - 1) * limit + (index + 1) %>
                                                        <% } %>
                                    </td>
                                    <td>
                                        <%=category.name%>
                                    </td>
                                    <td>
                                        <%=category.description%>
                                    </td>
                                    <td>
                                        <%if(category.isListed){%>
                                            <a href="/admin/unlistCategory?id=<%=category._id%>"
                                                class="btn btn-warning btn-sm"
                                                onclick="return confirmAction(event,'unlist','<%= category._id %>')">Unlist</a>
                                            <%}else{%>
                                                <a href="/admin/listCategory?id=<%=category._id%>"
                                                    class="btn btn-info btn-sm"
                                                    onclick="return confirmAction(event,'list','<%= category._id %>')">List</a>
                                                <%}%>
                                    </td>
                                    <td>
                                        <a href="/admin/editCategory?id=<%=category._id%>"
                                            class="btn btn-dark btn-sm">Edit</a>
                                    </td>
                                    <td>
                                        <button class="btn btn-dark btn-sm delete-btn"
                                            data-id="<%= category._id %>">Delete</button>
                                    </td>
                                </tr>
                                <%})%>
                        </tbody>
                    </table>
                </div>

                <div class="container mt-3 pagination-container">
                    <nav aria-label="Page Navigation">
                        <ul class="pagination pagination-custom justify-content-center mb-20">
                            <% for(let i=1; i <=totalPages; i++) { %>
                                <li class="page-item <%=(i === currentPage) ? 'active' : '' %>">
                                    <a class="page-link" href="?page=<%= i %>">
                                        <%= i %>
                                    </a>
                                </li>
                                <% } %>
                        </ul>
                    </nav>
                </div>



            </div>




            <!-- Bootstrap JS -->


            <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

            <script>
                const searchInput = document.getElementById('searchInput');
                const clearBtn = document.getElementById('clearSearch');

                // Show/hide clear button based on input
                searchInput.addEventListener('input', () => {
                    clearBtn.style.display = searchInput.value ? 'block' : 'none';
                });

                // Trigger search on Enter
                searchInput.addEventListener('keypress', function (e) {
                    if (e.key === 'Enter') {
                        const query = searchInput.value.trim();
                        window.location.href = `/admin/category?search=${encodeURIComponent(query)}&page=1`;
                    }
                });

                // Clear search
                clearBtn.addEventListener('click', () => {
                    searchInput.value = '';
                    clearBtn.style.display = 'none';
                    window.location.href = '/admin/category'; // Reload full list
                });

                // Initialize clear button on page load
                if (searchInput.value) {
                    clearBtn.style.display = 'block';
                }



                function confirmAction(event, action, id) {
                    event.preventDefault(); // Prevent the default <a> click

                    const actionText = action === 'list' ? 'List' : 'Unlist';
                    const buttonColor = action === 'list' ? '#3085d6' : '#d33';

                    Swal.fire({
                        title: 'Are you sure?',
                        text: `You are about to ${actionText.toLowerCase()} this category.`,
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonColor: buttonColor,
                        cancelButtonColor: '#aaa',
                        confirmButtonText: `Yes, ${actionText} it!`
                    }).then((result) => {
                        if (result.isConfirmed) {
                            fetch(`/admin/${action}Category?id=${id}`, {
                                method: 'GET'
                            })
                                .then(response => {
                                    if (!response.ok) {
                                        throw new Error('Failed to ' + action);
                                    }
                                    return response.json();
                                })
                                .then(data => {
                                    Swal.fire(
                                        `${actionText}ed!`,
                                        `User has been ${actionText.toLowerCase()}ed successfully.`,
                                        'success'
                                    ).then(() => {
                                        location.reload(); // Refresh the page to show updated status
                                    });
                                })
                                .catch(error => {
                                    Swal.fire(
                                        'Error!',
                                        'Something went wrong.',
                                        'error'
                                    );
                                });
                        }
                    });
                    return false; // Prevent default behavior
                }


                document.querySelectorAll('.delete-btn').forEach(button => {
                    button.addEventListener('click', function () {
                        const categoryId = this.dataset.id;
                        Swal.fire({
                            title: 'Are you sure?',
                            text: "Do you want to delete this category?",
                            icon: 'warning',
                            showCancelButton: true,
                            confirmButtonColor: '#d33',
                            cancelButtonColor: '#3085d6',
                            confirmButtonText: 'Yes, delete it!'
                        }).then((result) => {
                            if (result.isConfirmed) {
                                fetch(`/admin/deleteCategory/${categoryId}`, {
                                    method: 'DELETE', // use DELETE if route is delete
                                    headers: {
                                        'Content-Type': 'application/json'
                                    }
                                })
                                    .then(res => res.json())
                                    .then(data => {
                                        if (data.success) {
                                            Swal.fire('Deleted!', data.message, 'success').then(() => {
                                                location.reload(); // refresh page to show updated data
                                            });
                                        } else {
                                            Swal.fire('Oops!', data.message || 'Something went wrong.', 'error');
                                        }
                                    })
                                    .catch(err => {
                                        console.error(err);
                                        Swal.fire('Error', 'Could not delete category.', 'error');
                                    });
                            }
                        });
                    });
                });
            </script>

            <%-include("../../views/partials/admin/footer")%>