<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Admin Panel</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">



  <style>
    .admin-image {
      width: 40px;
      height: 40px;
      object-fit: cover;
      border-radius: 50%;
    }

    .nav-link {
      margin: 0 10px;
    }

    footer {
      background-color: #f8f9fa;
      padding: 10px 0;
      text-align: center;
      margin-top: auto;
    }

    .navbar {
      background-color: #343a40;
    }

    .navbar .nav-link,
    .navbar-brand,
    .dropdown-toggle {
      color: white;
    }

    .navbar .nav-link:hover,
    .navbar-brand:hover,
    .dropdown-item:hover {
      color: #ffc107;
    }

    body {
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }

    .content {
      flex: 1;
    }

    main {
      padding-top: 20px;
    }

    /* Basic page styling */
    body {
      font-family: Arial, sans-serif;
      background: #f4f6f9;
      margin: 0;
      padding: 0;
    }

    /* Content container */
    .content {
      max-width: 900px;
      margin: 40px auto;
      padding: 20px;
      background: #fff;
      border-radius: 8px;
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
    }

    /* Header */
    .header h1 {
      text-align: center;
      color: #333;
      margin-bottom: 20px;
    }

    /* Form container */
    .form-container {
      padding: 20px;
    }

    /* Table form layout */
    form table {
      width: 100%;
      border-spacing: 15px;
    }

    form table td:first-child {
      text-align: right;
      font-weight: bold;
      color: #444;
      vertical-align: top;
      padding-top: 8px;
    }

    form table td input,
    form table td textarea,
    form table td select {
      width: 100%;
      padding: 10px;
      border: 1px solid #ccc;
      border-radius: 6px;
      font-size: 14px;
      transition: border-color 0.2s ease-in-out;
    }

    form table td input:focus,
    form table td textarea:focus,
    form table td select:focus {
      outline: none;
      border-color: #4a90e2;
    }

    /* Image preview styling */
    .image-upload {
      margin-bottom: 10px;
    }

    .image-preview {
      display: block;
      margin-top: 8px;
      max-width: 150px;
      height: auto;
      border-radius: 6px;
      border: 1px solid #ddd;
    }

    /* Cropper modal styling */
    .modal {
      display: none;
      position: fixed;
      z-index: 1000;
      left: 0;
      top: 0;
      width: 100%;
      height: 100%;
      overflow: auto;
      background-color: rgba(0, 0, 0, 0.6);
    }

    .modal-content {
      background: #fff;
      margin: 50px auto;
      padding: 20px;
      border-radius: 8px;
      width: 80%;
      max-width: 600px;
      text-align: center;
    }

    .modal-content img {
      max-width: 100%;
      margin-bottom: 15px;
    }

    .modal-content button {
      background: #4a90e2;
      color: white;
      padding: 10px 15px;
      border: none;
      margin: 5px;
      border-radius: 5px;
      cursor: pointer;
    }

    .modal-content button:hover {
      background: #357ab7;
    }

    /* Submit button */
    .publish {
      display: block;
      margin: 25px auto 0 auto;
      padding: 12px 20px;
      background: #198754;
      color: white;
      font-size: 16px;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      transition: background 0.3s;
    }

  </style>
</head>

<body>

  <!-- Header -->
  <nav class="navbar navbar-expand-lg navbar-dark px-3">
    <a class="navbar-brand" href="#">The Untold Stories</a>

    <div class="collapse navbar-collapse justify-content-center">
      <ul class="navbar-nav">
        <li class="nav-item"><a class="nav-link" href="/admin/dashboard">Dashboard</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/users">Customers</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/category">Category</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/product">Product</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/banner">Banner</a></li>
        <li class="nav-item"><a class="nav-link" href="#">Coupon</a></li>
        <li class="nav-item"><a class="nav-link" href="#">Orders</a></li>
      </ul>
    </div>

    <!-- Admin Dropdown -->
    <div class="dropdown">
      <a href="#" class="d-flex align-items-center text-white text-decoration-none dropdown-toggle" id="adminDropdown"
        data-bs-toggle="dropdown" aria-expanded="false">
        <img src="/images/admin-icon.jpg" alt="Admin" class="admin-image">
      </a>
      <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="adminDropdown">
        <li><a class="dropdown-item" href="#" onclick="logout()">Logout</a></li>
      </ul>
    </div>
  </nav>



  <div class="content">
    <div class="header">
      <h1>Add New Product</h1>
    </div>
    <div class="form-container">
      <form action="/admin/addProduct" method="POST" enctype="multipart/form-data" id="productForm">
        <table>
          <tr>
            <td><label>Product Name</label></td>
            <td><input type="text" name="product_name" id="product_name">
              <div id="name-error" class="error-message text-danger small mt-1"></div>
            </td>
          </tr>
          <tr>
            <td><label>Full Description</label></td>
            <td><textarea name="description" rows="4" id="dec"></textarea>
              <div id="description-error" class="error-message text-danger small mt-1"></div>
            </td>
          </tr>
          <tr>
            <td><label>Price ($)</label></td>
            <td><input type="number" name="price" id="price">
              <div id="price-error" class="error-message text-danger small mt-1"></div>
            </td>
          </tr>
          <tr>
            <td><label>Author</label></td>
            <td><input type="text" name="author" id="author">
              <div id="author-error" class="error-message text-danger small mt-1"></div>
            </td>
          </tr>
          <tr>
            <td><label>Quantity</label></td>
            <td><input type="number" name="quantity" id="quantity">
              <div id="quantity-error" class="error-message text-danger small mt-1"></div>
            </td>
          </tr>
          <tr>
            <td><label>Category</label></td>
            <td>
              <select name="category" id="category">
                <% if (cat && cat.length> 0) { %>
                  <% for (let i=0; i < cat.length; i++) { %>
                    <option value="<%= cat[i].name %>">
                      <%= cat[i].name %>
                    </option>
                    <% } %>
                      <% } else { %>
                        <option value="">No Categories Available</option>
                        <% } %>
              </select>
            </td>
          </tr>
          <tr>
            <td><label>Upload Images</label></td>
            <td>
              <div class="image-upload">
                <input type="file" name="image1" id="image1" accept="image/*" onchange="handleFileSelect(event, 1)">
                <div id="image1-error" class="error-message text-danger small mt-1"></div>
              </div>
              <img id="preview1" class="image-preview">
            </td>
          </tr>
          <tr>
            <td></td>
            <td>
              <div class="image-upload">
                <input type="file" name="image2" id="image2" accept="image/*" onchange="handleFileSelect(event, 2)">
                <div id="image2-error" class="error-message text-danger small mt-1"></div>
              </div>
              <img id="preview2" class="image-preview">
            </td>
          </tr>
          <tr>
            <td></td>
            <td>
              <div class="image-upload">
                <input type="file" name="image3" id="image3" accept="image/*" onchange="handleFileSelect(event, 3)">
                <div id="image3-error" class="error-message text-danger small mt-1"></div>
              </div>
              <img id="preview3" class="image-preview">
            </td>
          </tr>
        </table>


        <div id="cropperModal" class="modal">
          <div class="modal-content">
            <img id="cropperImage" src="" style="max-width: 100%;" />
            <button type="button" onclick="cropImage()">Crop & Save</button>
            <button type="button" onclick="closeCropper()">Cancel</button>
          </div>
        </div>


        <button type="submit" class="publish">Publish</button>
      </form>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.12/cropper.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.12/cropper.min.css">


    <script>

      function validateForm() {
        clearErrorMessages()
        const productName = document.getElementById("product_name").value.trim();
        const description = document.getElementById("dec").value.trim();
        const author = document.getElementById('author').value.trim();
        const price = document.getElementById('price').value.trim();
        const quantity = document.getElementById('quantity').value.trim();
        const category = document.getElementById('category').value.trim();
        const image1 = document.getElementById('image1').files[0];
        const image2 = document.getElementById('image2').files[0];
        const image3 = document.getElementById('image3').files[0];
        const images = [image1, image2, image3]

        const nameRegex = /^[a-zA-Z\s]+$/;

        if (productName === '') {
          displayErrorMessage('name-error', 'Please enter a name.')
          return false;
        }

        if (description.length < 10) {
          displayErrorMessage('description-error', 'Description must be at least 10 characters long.')
          return false;
        }

        if (price === "" || isNaN(price) || parseFloat(price) <= 0) {
          displayErrorMessage('price-error', 'Price must be a valid number greater than 0.')
          return false;
        }

        if (!nameRegex.test(author)) {
          displayErrorMessage('author-error', 'Author name must contain only alphabets.')
          return false;
        }

        if (quantity === "" || isNaN(quantity) || parseInt(quantity) <= 0) {
          displayErrorMessage('quantity-error', 'Quantity must be a valid number greater than 0.')
          return false;
        }

        const allowedTypes = ["image/png", "image/jpeg", "image/jpg"];

        for (let i = 0; i < images.length; i++) {
          if (images[i] && !allowedTypes.includes(images[i].type)) {
            displayErrorMessage(`image${i + 1}-error`, "Only PNG and JPG files are allowed.");
            return false;
          }
        }

        return true;
      }


      // Displays error message in the specified element
      function displayErrorMessage(elementId, message) {
        let errorElement = document.getElementById(elementId)
        errorElement.innerText = message
        errorElement.style.display = 'block'
      }


      // Clears all error messages displayed in the form
      function clearErrorMessages() {
        let errorElements = document.getElementsByClassName('error-message')
        Array.from(errorElements).forEach((element) => {
          element.innerText = ''
          element.style.display = 'none'
        })
      }

      let cropper;
      let currentImageIndex;

      function handleFileSelect(event, index) {
        const file = event.target.files[0];
        if (file) {
          // Allowed file types
          const allowedTypes = ["image/png", "image/jpeg", "image/jpg"];
          if (!allowedTypes.includes(file.type)) {
            Swal.fire("Invalid File Type", "Only PNG and JPG files are allowed.", "error");
            event.target.value = ""; // Clear the invalid file input
            return;
          }

          currentImageIndex = index;
          const reader = new FileReader();
          reader.onload = function (e) {
            document.getElementById(`preview${index}`).src = e.target.result;
            document.getElementById('cropperImage').src = e.target.result;
            openCropper();
          };
          reader.readAsDataURL(file);
        }
      }
      function openCropper() {
        document.getElementById('cropperModal').style.display = 'block';
        const image = document.getElementById('cropperImage');
        cropper = new Cropper(image, {
          aspectRatio: 1,
          viewMode: 1
        });
      }
      function cropImage() {
        const canvas = cropper.getCroppedCanvas({ width: 440, height: 600 });
        canvas.toBlob(blob => {
          const file = new File([blob], `cropped_image_${currentImageIndex}.png`, { type: "image/png" });

          const dataTransfer = new DataTransfer();
          dataTransfer.items.add(file);
          document.getElementById(`image${currentImageIndex}`).files = dataTransfer.files;

          document.getElementById(`preview${currentImageIndex}`).src = URL.createObjectURL(blob);

          closeCropper();
        });
      }


      function closeCropper() {
        document.getElementById('cropperModal').style.display = 'none';
        cropper.destroy();
      }

      function clearForm() {
        document.getElementById("product_name").value = "";
        document.getElementById("dec").value = "";
        document.getElementById("price").value = "";
        document.getElementById("author").value = "";
        document.getElementById("quantity").value = "";
        document.getElementById("category").selectedIndex = 0;

        for (let i = 1; i <= 3; i++) {
          let fileInput = document.getElementById(`image${i}`);
          let imgPreview = document.getElementById(`preview${i}`);

          fileInput.value = "";
          imgPreview.src = "";

          localStorage.removeItem(`croppedImage_${i}`);
          localStorage.removeItem(`imageName_${i}`);
        }
      }



      function showSuccessMessage() {
        Swal.fire({
          title: "Success!",
          text: "Product added successfully!",
          icon: "success",
          confirmButtonText: "OK"
        }).then(() => {
          clearForm();
          localStorage.clear();
          sessionStorage.removeItem("imagesLoaded");
          window.location.href = '/admin/product'
        });
      }


      document.getElementById("productForm").addEventListener("submit", async function (event) {
        event.preventDefault();
        if (!validateForm()) {
          return;
        }
        const formData = new FormData(this);
        try {
          const response = await fetch("/admin/addProduct", {
            method: "POST",
            body: formData
          });
          const data = await response.json();
          if (response.ok && data.message === "Product added successfully!") {
            showSuccessMessage();
          } else {
            Swal.fire("Error", "Failed to add product.", "error");
          }
        } catch (error) {
          console.error("Error:", error);
          Swal.fire("Error", "Something went wrong.", "error");
        }
      });

    </script>



    <!-- Footer -->

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>

      async function logout() {
        try {
          const response = await fetch('/admin/logout', { method: 'GET' });
          if (response.ok) {
            window.location.href = '/admin/login'
          } else {
            console.error('Logout failed')
          }
        } catch (error) {
          console.error('Error during logout', error)

        }
      }

    </script>
    
</body>
</html>