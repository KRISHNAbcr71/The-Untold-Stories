<%-include("../../views/partials/admin/header")%>
<link rel="stylesheet" href="/css/add-offer.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">



    <!-- Edit Offer Page with Custom Design -->
<div class="edit-offer-wrapper">
    <!-- Page Header -->
    <div class="page-header">
        <div class="header-content">
            <div class="header-icon">
                <i class="bi bi-pencil-square" style="font-size: 1.5rem;"></i>
            </div>
            <div>
                <h1 class="page-title">Edit Offer</h1>
                <p class="page-subtitle">Update offer details</p>
            </div>
        </div>
        <a href="/admin/offer" class="back-link">
            <i class="bi bi-arrow-left"></i>
            <span>Back to Offers</span>
        </a>
    </div>

    <!-- Main Form Card -->
    <div class="form-card">
        <div class="card-pattern"></div>
        <div class="form-fields">
            <form id="offerForm" onsubmit="return handleFormSubmit(event)">
                <input type="hidden" name="id" value="<%= offer._id %>">

                <!-- Form Grid Layout -->
                <div class="form-grid">
                    <!-- Left Column -->
                    <div>
                        <!-- Offer Name -->
                        <div class="field-group">
                            <label for="offerName" class="field-label">
                                <i class="bi bi-tag-fill"></i>
                                Offer Name
                            </label>
                            <div class="input-wrapper">
                                <input type="text" class="form-control" id="offerName" name="name" 
                                       value="<%= offer.name %>" placeholder="e.g. New Year Offer">
                                <div class="input-border"></div>
                            </div>
                        </div>

                        <!-- Discount Value -->
                        <div class="field-group">
                            <label for="discountValue" class="field-label">
                                <i class="bi bi-percent"></i>
                                Discount Value (%)
                            </label>
                            <div class="input-wrapper">
                                <input type="number" class="form-control" id="discountValue" name="discountValue" 
                                       value="<%= offer.discountValue %>" placeholder="Enter discount (e.g. 10)">
                                <div class="input-border"></div>
                            </div>
                        </div>

                        <!-- Applies To (Read Only) -->
                        <div class="field-group">
                            <label class="field-label">
                                <i class="bi bi-grid-3x3-gap-fill"></i>
                                Applies To
                            </label>
                            <div class="radio-group readonly">
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="appliesTo" value="product"
                                        <%= offer.appliesTo === 'product' ? 'checked' : '' %> disabled>
                                    <label class="form-check-label" for="radioProduct">
                                        <i class="bi bi-box-seam"></i> Product
                                    </label>
                                </div>
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="appliesTo" value="category"
                                        <%= offer.appliesTo === 'category' ? 'checked' : '' %> disabled>
                                    <label class="form-check-label" for="radioCategory">
                                        <i class="bi bi-folder"></i> Category
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Right Column -->
                    <div>
                        <!-- Start Date -->
                        <div class="field-group">
                            <label for="startDate" class="field-label">
                                <i class="bi bi-calendar-check"></i>
                                Start Date
                            </label>
                            <div class="input-wrapper">
                                <input type="date" class="form-control" name="startDate" id="startDate"
                                       value="<%= offer.startDate.toISOString().split('T')[0] %>">
                                <div class="input-border"></div>
                            </div>
                        </div>

                        <!-- End Date -->
                        <div class="field-group">
                            <label for="endDate" class="field-label">
                                <i class="bi bi-calendar-x"></i>
                                End Date
                            </label>
                            <div class="input-wrapper">
                                <input type="date" class="form-control" name="endDate" id="endDate"
                                       value="<%= offer.endDate.toISOString().split('T')[0] %>">
                                <div class="input-border"></div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Selected Targets Section -->
                <div class="targets-section">
                    <div class="section-title">
                        <i class="bi bi-check2-square"></i>
                        <span>Selected Targets</span>
                    </div>

                    <div class="selected-targets-container">
                        <% if (offer.appliesTo === 'product') { %>
                            <% if (products.length > 0) { %>
                                <div class="targets-badge-grid">
                                    <% products.forEach(product => { %>
                                        <% const isSelected = offer.targetIds.some(id => id.toString() === product._id.toString()); %>
                                        <% if (isSelected) { %>
                                            <span class="target-badge">
                                                <i class="bi bi-box"></i>
                                                <%= product.productName %>
                                            </span>
                                        <% } %>
                                    <% }) %>
                                </div>
                            <% } else { %>
                                <p class="text-muted">No products selected</p>
                            <% } %>
                        <% } else { %>
                            <% if (categories.length > 0) { %>
                                <div class="targets-badge-grid">
                                    <% categories.forEach(category => { %>
                                        <% const isSelected = offer.targetIds.some(id => id.toString() === category._id.toString()); %>
                                        <% if (isSelected) { %>
                                            <span class="target-badge">
                                                <i class="bi bi-folder"></i>
                                                <%= category.name %>
                                            </span>
                                        <% } %>
                                    <% }) %>
                                </div>
                            <% } else { %>
                                <p class="text-muted">No categories selected</p>
                            <% } %>
                        <% } %>
                    </div>
                    <div class="mt-2">
                        <small class="text-muted">
                            <i class="bi bi-info-circle"></i>
                            Targets cannot be modified after creation
                        </small>
                    </div>
                </div>

                <!-- Form Footer -->
                <div class="form-footer">
                    <div class="footer-decoration"></div>
                    <div class="button-group">
                        <a href="/admin/offer" class="btn btn-outline">
                            <i class="bi bi-x-circle"></i>
                            <span>Cancel</span>
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle"></i>
                            <span>Update Offer</span>
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Quick Tips -->
    <div class="tips-grid">
        <div class="tip-card">
            <div class="tip-icon">
                <i class="bi bi-lightbulb-fill"></i>
            </div>
            <div>
                <h4>Update Dates</h4>
                <p>You can only modify start and end dates</p>
            </div>
        </div>
        <div class="tip-card">
            <div class="tip-icon">
                <i class="bi bi-calendar-range"></i>
            </div>
            <div>
                <h4>Date Range</h4>
                <p>End date must be after start date</p>
            </div>
        </div>
        <div class="tip-card">
            <div class="tip-icon">
                <i class="bi bi-lock-fill"></i>
            </div>
            <div>
                <h4>Fixed Targets</h4>
                <p>Targets cannot be changed after creation</p>
            </div>
        </div>
    </div>
</div>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>


    <script>
    // Fix typo: wwindow.onload -> window.onload
    window.onload = () => {
        const today = new Date().toISOString().split('T')[0];
        const startDateInput = document.getElementById('startDate');
        if (startDateInput && !startDateInput.min) {
            startDateInput.min = today;
        }
    };

    // Form submit handler
    async function handleFormSubmit(event) {
        event.preventDefault();

        const id = document.querySelector('input[name="id"]').value;
        const name = document.getElementById('offerName').value.trim();
        const discountValue = Number(document.getElementById('discountValue').value);
        const startDate = document.getElementById('startDate').value;
        const endDate = document.getElementById('endDate').value;

        // Validation
        if (!name || !discountValue || !startDate || !endDate) {
            return Swal.fire({
                icon: 'error',
                title: 'Error',
                text: 'All fields are required',
                confirmButtonColor: '#d4a373'
            });
        }

        if (discountValue <= 0 || discountValue > 100) {
            return Swal.fire({
                icon: 'error',
                title: 'Error',
                text: 'Enter a valid discount value between 1 and 100',
                confirmButtonColor: '#d4a373'
            });
        }

        if (startDate === endDate) {
            return Swal.fire({
                icon: 'error',
                title: 'Error',
                text: 'Start date and end date cannot be the same',
                confirmButtonColor: '#d4a373'
            });
        }

        if (endDate < startDate) {
            return Swal.fire({
                icon: 'error',
                title: 'Error',
                text: 'End date must be after start date',
                confirmButtonColor: '#d4a373'
            });
        }

        try {
            const response = await fetch(`/admin/editOffer/${id}`, {
                method: 'PATCH',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    name: name,
                    discountValue: discountValue,
                    startDate: startDate,
                    endDate: endDate
                })
            });

            const data = await response.json();

            if (!response.ok) {
                throw new Error(data.message || 'Failed to update offer');
            }

            Swal.fire({
                icon: 'success',
                title: 'Success!',
                text: 'Offer updated successfully',
                confirmButtonColor: '#d4a373'
            }).then(() => {
                window.location.href = '/admin/offer';
            });

        } catch (error) {
            Swal.fire({
                icon: 'error',
                title: 'Error',
                text: error.message || 'Failed to update offer',
                confirmButtonColor: '#d4a373'
            });
        }
    }
</script>
