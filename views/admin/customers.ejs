<%-include("../../views/partials/admin/header")%>
  <link rel="stylesheet" href="/css/customers.css">


  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <h2 class="fw-bold mb-0 ps-4">👥 Customers</h2>
    <div class="search-container position-relative">
      <input type="text" class="form-control" id="searchInput" placeholder="Search customers..."
        value="<%= search || '' %>">
      <span class="search-clear" id="clearSearch" style="display:none;">&times;</span>
    </div>
  </div>

  


  <!-- If no results -->
  <% if (noResults) { %>
    <div class="text-center text-danger mb-3">No results found</div>
    <% } %>


      <!-- Customer Table -->
       <div class="table-wrapper">
        <%if(data){%>
        <div class="table-responsive container-fluid">
          <table class="table admin-table" >
            <thead class="table-secondary">
              <tr>
                <th>Number</th>
                <th>Name</th>
                <th>Email</th>
                <th>Phone Number</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody id="customerTableBody">
              <%for(let i=0; i<data.length; i++){%>
                <tr>
                  <td>
                    <%= data[i].globalIndex %>
                  </td>
                  <td>
                    <%=data[i].name%>
                  </td>
                  <td>
                    <%=data[i].email%>
                  </td>
                  <td>
                    <%=data[i].phone%>
                  </td>
                  <td>
                    <%if(data[i].isBlocked===false){%>

                      <a class="btn btn-sm btn-danger" href="/admin/blockCustomer?id=<%=data[i]._id%>"
                        style="text-decoration: none; color: white;"
                        onclick="return confirmAction(event,'block','<%= data[i]._id %>')">Block</a>

                      <%}else{%>

                        <a class="btn btn-sm btn-success" href="/admin/unblockCustomer?id=<%=data[i]._id%>"
                          style="text-decoration: none; color: white;"
                          onclick="return confirmAction(event,'unblock','<%= data[i]._id %>')">Unblock</a>

                        <%}%>
                  </td>
                </tr>
                <%}%>
            </tbody>
          </table>
        </div>
        <%}else{%>
          <div class="alert alert-warning text-center mt-4">
            🔍 No User found
          </div>
          <%}%>




          <div class="container-fluid mt-3 pagination-container">
              <nav aria-label="Page Navigation">
                <ul class="pagination pagination-custom justify-content-center mb-20">
                  <% for(let i=1; i <=totalPages; i++) { %>
                    <li class="page-item <%=(i === currentPage) ? 'active' : '' %>">
                      <a class="page-link" href="?page=<%= i %>">
                        <%= i %>
                      </a>
                    </li>
                    <% } %>
                </ul>
              </nav>
            </div>
       </div>
      

            

            <!-- Bootstrap JS -->
            <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
            <script>

              const searchInput = document.getElementById('searchInput');
              const clearBtn = document.getElementById('clearSearch');

              // Show/hide clear button based on input
              searchInput.addEventListener('input', () => {
                clearBtn.style.display = searchInput.value ? 'block' : 'none';
              });

              // Trigger search on Enter
              searchInput.addEventListener('keypress', function (e) {
                if (e.key === 'Enter') {
                  const query = searchInput.value.trim();
                  window.location.href = `/admin/users?search=${encodeURIComponent(query)}&page=1`;
                }
              });

              // Clear search
              clearBtn.addEventListener('click', () => {
                searchInput.value = '';
                clearBtn.style.display = 'none';
                window.location.href = '/admin/users'; 
              });

              // Initialize clear button on page load
              if (searchInput.value) {
                clearBtn.style.display = 'block';
              }

              function confirmAction(event, action, id) {
                event.preventDefault(); 

                const actionText = action === 'block' ? 'Block' : 'Unblock';
                const buttonColor = action === 'block' ? '#d33' : '#3085d6';

                Swal.fire({
                  title: 'Are you sure?',
                  text: `You are about to ${actionText.toLowerCase()} this user.`,
                  icon: 'warning',
                  showCancelButton: true,
                  confirmButtonColor: buttonColor,
                  cancelButtonColor: '#aaa',
                  confirmButtonText: `Yes, ${actionText} it!`
                }).then((result) => {
                  if (result.isConfirmed) {
                    fetch(`/admin/${action}Customer?id=${id}`, {
                      method: 'GET'
                    })
                      .then(response => {
                        if (!response.ok) {
                          throw new Error('Failed to ' + action);
                        }
                        return response.json();
                      })
                      .then(data => {
                        Swal.fire(
                          `${actionText}ed!`,
                          `User has been ${actionText.toLowerCase()}ed successfully.`,
                          'success'
                        ).then(() => {
                          location.reload(); 
                        });
                      })
                      .catch(error => {
                        Swal.fire(
                          'Error!',
                          'Something went wrong.',
                          'error'
                        );
                      });
                  }
                });

                return false; 
              }

            </script>
            
            <%-include("../../views/partials/admin/footer")%>