<%-include("../../views/partials/admin/header")%>
    <link rel="stylesheet" href="/css/add-product.css">



    <!-- Main Content -->
    <div class="content">
        <!-- Page Header -->
        <div class="page-header">
            <div class="header-content">
                <div class="header-icon">
                    <i class="bi bi-pencil-square" style="font-size: 1.5rem;"></i>
                </div>
                <div>
                    <h1 class="page-title">Edit Product</h1>
                    <p class="page-subtitle">Update product information</p>
                </div>
            </div>
            <a href="/admin/product" class="back-link">
                <i class="bi bi-arrow-left"></i>
                <span>Back to Products</span>
            </a>
        </div>

        <!-- Main Form Card -->
        <div class="form-card">
            <div class="card-pattern"></div>
            <div class="form-fields">
                <form method="POST" enctype="multipart/form-data" id="productForm" novalidate>
                    <!-- Form Grid Layout -->
                    <div class="form-grid">
                        <!-- Left Column -->
                        <div>
                            <!-- Product Name -->
                            <div class="field-group">
                                <label for="product_name" class="field-label">
                                    <i class="bi bi-tag-fill"></i>
                                    Product Name
                                </label>
                                <div class="input-wrapper">
                                    <input type="text" class="form-control" id="product_name" name="product_name"
                                        value="<%= product.productName %>" placeholder="e.g., The Great Gatsby">
                                    <div class="input-border"></div>
                                </div>
                                <div id="name-error" class="error-message">
                                    <i class="bi bi-exclamation-circle-fill"></i>
                                    <span></span>
                                </div>
                            </div>

                            <!-- Price -->
                            <div class="field-group">
                                <label for="price" class="field-label">
                                    <i class="bi bi-currency-dollar"></i>
                                    Price ($)
                                </label>
                                <div class="input-wrapper">
                                    <input type="number" class="form-control" id="price" name="price"
                                        value="<%= product.price %>" placeholder="29.99" step="0.01">
                                    <div class="input-border"></div>
                                </div>
                                <div id="price-error" class="error-message">
                                    <i class="bi bi-exclamation-circle-fill"></i>
                                    <span></span>
                                </div>
                            </div>

                            <!-- Author -->
                            <div class="field-group">
                                <label for="author" class="field-label">
                                    <i class="bi bi-pencil-fill"></i>
                                    Author
                                </label>
                                <div class="input-wrapper">
                                    <input type="text" class="form-control" id="author" name="author"
                                        value="<%= product.author %>" placeholder="e.g., F. Scott Fitzgerald">
                                    <div class="input-border"></div>
                                </div>
                                <div id="author-error" class="error-message">
                                    <i class="bi bi-exclamation-circle-fill"></i>
                                    <span></span>
                                </div>
                            </div>
                        </div>

                        <!-- Right Column -->
                        <div>
                            <!-- Quantity -->
                            <div class="field-group">
                                <label for="quantity" class="field-label">
                                    <i class="bi bi-box-fill"></i>
                                    Quantity
                                </label>
                                <div class="input-wrapper">
                                    <input type="number" class="form-control" id="quantity" name="quantity"
                                        value="<%= product.quantity %>" placeholder="100">
                                    <div class="input-border"></div>
                                </div>
                                <div id="quantity-error" class="error-message">
                                    <i class="bi bi-exclamation-circle-fill"></i>
                                    <span></span>
                                </div>
                            </div>

                            <!-- Category -->
                            <div class="field-group">
                                <label for="category" class="field-label">
                                    <i class="bi bi-grid-fill"></i>
                                    Category
                                </label>
                                <div class="input-wrapper">
                                    <select class="form-select" id="category" name="category">
                                        <option value="" disabled>Select a category</option>
                                        <% if (cat && cat.length> 0) { %>
                                            <% cat.forEach(function(catItem) { %>
                                                <option value="<%= catItem._id %>"
                                                    <%=product.category._id.toString()===catItem._id.toString()
                                                    ? 'selected' : '' %>>
                                                    <%= catItem.name %>
                                                </option>
                                                <% }); %>
                                                    <% } else { %>
                                                        <option value="" disabled>No Categories Available</option>
                                                        <% } %>
                                    </select>
                                    <div class="input-border"></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Full Description (Full Width) -->
                    <div class="field-group">
                        <label for="dec" class="field-label">
                            <i class="bi bi-card-text"></i>
                            Full Description
                        </label>
                        <div class="input-wrapper">
                            <textarea class="form-control" id="dec" name="description" rows="4"
                                placeholder="Provide a detailed description of the product..."><%= product.description %></textarea>
                            <div class="input-border"></div>
                        </div>
                        <div id="description-error" class="error-message">
                            <i class="bi bi-exclamation-circle-fill"></i>
                            <span></span>
                        </div>
                    </div>

                    <!-- Image Upload Section -->
                    <div class="image-upload-section">
                        <div class="section-title">
                            <i class="bi bi-images"></i>
                            <span>Product Images</span>
                        </div>

                        <div class="image-grid">
                            <!-- Image 1 -->
                            <div class="image-upload-card">
                                <div class="image-upload-header">
                                    <div class="image-upload-header-left">
                                        <i class="bi bi-image-fill"></i>
                                        <span>Main Image</span>
                                    </div>
                                    <% if (product.productImage && product.productImage[0]) { %>
                                        <button type="button" class="delete-btn"
                                            onclick="deleteSingleImage(event,'<%= product.productImage[0] %>', '<%= product._id %>', 1)">
                                            <i class="bi bi-trash"></i> Delete
                                        </button>
                                        <% } %>
                                </div>
                                <div class="file-input-wrapper">
                                    <input type="file" name="image1" id="image1" accept="image/*"
                                        onchange="previewImage(event, 1)">
                                </div>
                                <div class="image-container">
                                    <img src="/<%= product.productImage && product.productImage[0] ? product.productImage[0] : 'default.jpg' %>"
                                        alt="Product Image" class="image-preview" id="preview1">
                                </div>
                                <div id="image1-error" class="error-message">
                                    <i class="bi bi-exclamation-circle-fill"></i>
                                    <span></span>
                                </div>
                            </div>

                            <!-- Image 2 -->
                            <div class="image-upload-card">
                                <div class="image-upload-header">
                                    <div class="image-upload-header-left">
                                        <i class="bi bi-image-fill"></i>
                                        <span>Image 2</span>
                                    </div>
                                    <% if (product.productImage && product.productImage[1]) { %>
                                        <button type="button" class="delete-btn"
                                            onclick="deleteSingleImage(event,'<%= product.productImage[1] %>', '<%= product._id %>', 2)">
                                            <i class="bi bi-trash"></i> Delete
                                        </button>
                                        <% } %>
                                </div>
                                <div class="file-input-wrapper">
                                    <input type="file" name="image2" id="image2" accept="image/*"
                                        onchange="previewImage(event, 2)">
                                </div>
                                <div class="image-container">
                                    <img src="/<%= product.productImage && product.productImage[1] ? product.productImage[1] : 'default.jpg' %>"
                                        alt="Product Image" class="image-preview" id="preview2">
                                </div>
                                <div id="image2-error" class="error-message">
                                    <i class="bi bi-exclamation-circle-fill"></i>
                                    <span></span>
                                </div>
                            </div>

                            <!-- Image 3 -->
                            <div class="image-upload-card">
                                <div class="image-upload-header">
                                    <div class="image-upload-header-left">
                                        <i class="bi bi-image-fill"></i>
                                        <span>Image 3</span>
                                    </div>
                                    <% if (product.productImage && product.productImage[2]) { %>
                                        <button type="button" class="delete-btn"
                                            onclick="deleteSingleImage(event,'<%= product.productImage[2] %>', '<%= product._id %>', 3)">
                                            <i class="bi bi-trash"></i> Delete
                                        </button>
                                        <% } %>
                                </div>
                                <div class="file-input-wrapper">
                                    <input type="file" name="image3" id="image3" accept="image/*"
                                        onchange="previewImage(event, 3)">
                                </div>
                                <div class="image-container">
                                    <img src="/<%= product.productImage && product.productImage[2] ? product.productImage[2] : 'default.jpg' %>"
                                        alt="Product Image" class="image-preview" id="preview3">
                                </div>
                                <div id="image3-error" class="error-message">
                                    <i class="bi bi-exclamation-circle-fill"></i>
                                    <span></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Form Footer -->
                    <div class="form-footer">
                        <div class="footer-decoration"></div>
                        <div class="button-group">
                            <button type="button" class="btn btn-outline"
                                onclick="window.location.href='/admin/product'">
                                <i class="bi bi-x-circle"></i>
                                <span>Cancel</span>
                            </button>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle"></i>
                                <span>Update Product</span>
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <!-- Quick Tips -->
        <div class="tips-grid">
            <div class="tip-card">
                <div class="tip-icon">
                    <i class="bi bi-lightbulb-fill"></i>
                </div>
                <div>
                    <h4>Update Carefully</h4>
                    <p>Review all changes before updating the product</p>
                </div>
            </div>
            <div class="tip-card">
                <div class="tip-icon">
                    <i class="bi bi-file-text-fill"></i>
                </div>
                <div>
                    <h4>Keep Details Accurate</h4>
                    <p>Ensure product information is up to date</p>
                </div>
            </div>
            <div class="tip-card">
                <div class="tip-icon">
                    <i class="bi bi-tags-fill"></i>
                </div>
                <div>
                    <h4>Image Quality</h4>
                    <p>Use high-quality images for better presentation</p>
                </div>
            </div>
        </div>
    </div>






    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.12/cropper.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.12/cropper.min.js"></script>

    <script>
        let cropper;

        document.getElementById('productForm').addEventListener('submit', async function (e) {
            e.preventDefault();

            if (!validateForm()) return;

            const form = e.target;
            const productId = "<%= product._id %>";
            const formData = new FormData(form);

            try {
                Swal.fire({
                    title: 'Updating product...',
                    allowOutsideClick: false,
                    didOpen: () => Swal.showLoading()
                });

                const response = await fetch(`/admin/editProduct/${productId}`, {
                    method: 'POST',
                    body: formData
                });

                const data = await response.json();
                Swal.close();

                if (response.ok) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Product Updated',
                        text: data.message || 'The product has been updated successfully.',
                        confirmButtonColor: '#d4a373'
                    }).then(() => {
                        window.location.href = '/admin/product';
                    });
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Update Failed',
                        text: data.error || 'Something went wrong while updating the product.',
                        confirmButtonColor: '#e74c3c'
                    });
                }
            } catch (error) {
                console.error('Error:', error);
                Swal.close();
                Swal.fire({
                    icon: 'error',
                    title: 'Error!',
                    text: 'An unexpected error occurred.',
                    confirmButtonColor: '#e74c3c'
                });
            }
        });

        function validateForm() {
            clearErrorMessages();
            const productName = document.getElementById("product_name").value.trim();
            const description = document.getElementById("dec").value.trim();
            const author = document.getElementById('author').value.trim();
            const price = document.getElementById('price').value.trim();
            const quantity = document.getElementById('quantity').value.trim();
            let isValid = true;

            const nameRegex = /^[a-zA-Z\s]+$/;

            if (productName === '') {
                displayErrorMessage('name-error', 'Please enter a product name.');
                isValid = false;
            }

            if (description.length < 10) {
                displayErrorMessage('description-error', 'Description must be at least 10 characters long.');
                isValid = false;
            }

            if (price === "" || isNaN(price) || parseFloat(price) < 0) {
                displayErrorMessage('price-error', 'Price must be a valid number (0 or more).');
                isValid = false;
            }

            if (!nameRegex.test(author)) {
                displayErrorMessage('author-error', 'Author name must contain only alphabets.');
                isValid = false;
            }

            if (quantity === "" || isNaN(quantity) || parseInt(quantity) < 0) {
                displayErrorMessage('quantity-error', 'Quantity must be a valid number (0 or more).');
                isValid = false;
            }

            return isValid;
        }

        function displayErrorMessage(elementId, message) {
            let errorElement = document.getElementById(elementId);
            if (errorElement) {
                errorElement.querySelector('span').innerText = message;
                errorElement.style.display = 'flex';
            }
        }

        function clearErrorMessages() {
            let errorElements = document.getElementsByClassName('error-message');
            Array.from(errorElements).forEach((element) => {
                element.querySelector('span').innerText = '';
                element.style.display = 'none';
            });
        }

        function setupRealTimeValidation() {
            const inputs = [
                { id: 'product_name', errorId: 'name-error' },
                { id: 'dec', errorId: 'description-error' },
                { id: 'price', errorId: 'price-error' },
                { id: 'author', errorId: 'author-error' },
                { id: 'quantity', errorId: 'quantity-error' }
            ];

            inputs.forEach(input => {
                const element = document.getElementById(input.id);
                const errorElement = document.getElementById(input.errorId);
                if (element && errorElement) {
                    element.addEventListener('input', function () {
                        if (this.value.trim() !== '') {
                            errorElement.style.display = 'none';
                            errorElement.querySelector('span').innerText = '';
                        }
                    });
                }
            });
        }

        function previewImage(event, index) {
            const file = event.target.files[0];

            if (file) {
                const allowedTypes = ["image/jpeg", "image/png", "image/jpg"];

                if (!allowedTypes.includes(file.type)) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Invalid File',
                        text: 'Only JPG and PNG formats are allowed.',
                        confirmButtonColor: '#d4a373'
                    });
                    event.target.value = "";
                    return;
                }

                const reader = new FileReader();
                reader.onload = function (e) {
                    showCropperModal(e.target.result, index);
                };
                reader.readAsDataURL(file);
            }
        }

        function showCropperModal(imageSrc, index) {
            Swal.fire({
                title: 'Crop Image',
                html: '<img id="cropperImage" src="' + imageSrc + '" style="max-width:100%;">',
                showCancelButton: true,
                confirmButtonText: 'Crop',
                cancelButtonText: 'Cancel',
                width: '600px',
                willOpen: () => {
                    const image = document.getElementById('cropperImage');
                    cropper = new Cropper(image, {
                        aspectRatio: 440 / 600,
                        viewMode: 1,
                    });
                },
                preConfirm: () => {
                    return new Promise((resolve) => {
                        if (cropper) {
                            const canvas = cropper.getCroppedCanvas({ width: 440, height: 600 });
                            canvas.toBlob(blob => {
                                const file = new File([blob], `cropped_image_${index}.png`, { type: "image/png" });

                                const dataTransfer = new DataTransfer();
                                dataTransfer.items.add(file);
                                document.getElementById(`image${index}`).files = dataTransfer.files;

                                resolve(URL.createObjectURL(blob));
                            });
                        } else {
                            resolve(imageSrc);
                        }
                    });
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById(`preview${index}`).src = result.value;
                    Swal.fire({
                        icon: 'success',
                        title: 'Cropped!',
                        text: 'Image cropped successfully.',
                        timer: 1500,
                        showConfirmButton: false
                    });
                }
                if (cropper) {
                    cropper.destroy();
                }
            });
        }

        async function deleteSingleImage(event, imageName, productId, index) {
            if (event) {
                event.preventDefault();
            }

            const confirmDelete = await Swal.fire({
                title: "Are you sure?",
                text: "This image will be permanently deleted!",
                icon: "warning",
                showCancelButton: true,
                confirmButtonText: "Yes, delete it!",
                cancelButtonText: "Cancel",
                confirmButtonColor: '#e74c3c',
                cancelButtonColor: '#6d6a64'
            });

            if (confirmDelete.isConfirmed) {
                try {
                    const response = await fetch(`/admin/deleteImage/${productId}/${encodeURIComponent(imageName)}`, {
                        method: "DELETE",
                    });

                    if (!response.ok) {
                        const errorText = await response.text();
                        throw new Error(`HTTP error! status: ${response.status}, message: ${errorText}`);
                    }

                    const data = await response.json();

                    if (response.ok && data.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Deleted!',
                            text: 'Image has been removed successfully.',
                            timer: 1500,
                            showConfirmButton: false
                        });
                        document.getElementById(`preview${index}`).src = "/default.jpg";

                        // Hide or remove the delete button
                        const deleteBtn = event.target.closest('.delete-btn');
                        if (deleteBtn) {
                            deleteBtn.remove();
                        }

                        const imageCard = event.target.closest('.image-upload-card');
                        if (imageCard) {
                            const header = imageCard.querySelector('.image-upload-header');
                            if (header) {
                                const deleteBtnInHeader = header.querySelector('.delete-btn');
                                if (deleteBtnInHeader) {
                                    deleteBtnInHeader.remove();
                                }
                            }
                        }
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Error',
                            text: data.error || 'Failed to delete image.',
                            confirmButtonColor: '#d4a373'
                        });
                    }
                } catch (error) {
                    let errorMessage = 'Something went wrong!';
                    if (error.message.includes('Failed to fetch')) {
                        errorMessage = 'Network error: Could not connect to server. Please check your connection.';
                    } else if (error.message.includes('404')) {
                        errorMessage = 'Error: Delete endpoint not found. Please check the URL.';
                    } else if (error.message.includes('500')) {
                        errorMessage = 'Server error: Please try again later.';
                    }


                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: 'Something went wrong!',
                        confirmButtonColor: '#d4a373'
                    });
                }
            }
        }

        async function logout() {
            try {
                const response = await fetch('/admin/logout', { method: 'GET' });
                if (response.ok) {
                    window.location.href = '/admin/login';
                } else {
                    console.error('Logout failed');
                }
            } catch (error) {
                console.error('Error during logout', error);
            }
        }


        document.addEventListener('DOMContentLoaded', function () {
            setupRealTimeValidation();
        });
    </script>


    <%-include("../../views/partials/admin/footer")%>