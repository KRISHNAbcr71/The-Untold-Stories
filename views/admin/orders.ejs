<%-include("../../views/partials/admin/header")%>
  <link rel="stylesheet" href="/css/order.css">

  <div class="container">
    <h2 class="fw-bold mb-4 mt-4">🛍️ Orders</h2>
    <div class="card orders-card shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h4 class="mb-0">Orders</h4>
        </div>

        <!-- Controls -->
        <div class="row g-2 align-items-center mb-3">
          <div class="col-md-4">
            <input id="searchInput" type="search" class="form-control" value="<%= search || '' %>"
              placeholder="Search by order ID or user name">
          </div>
          <div class="col-md-2">
            <select id="statusFilter" class="form-select" onchange="applyFilters()">
              <option value="" <%=!statusFilter ? 'selected' : '' %>>All Statuses</option>
              <option value="pending" <%=statusFilter==='pending' ? 'selected' : '' %>>Pending</option>
              <option value="shipped" <%=statusFilter==='shipped' ? 'selected' : '' %>>Shipped</option>
              <option value="out for delivery" <%=statusFilter==='out for delivery' ? 'selected' : '' %>>Out for
                Delivery</option>
              <option value="delivered" <%=statusFilter==='delivered' ? 'selected' : '' %>>Delivered</option>
              <option value="cancelled" <%=statusFilter==='cancelled' ? 'selected' : '' %>>Cancelled</option>
              <option value="partially returned" <%=statusFilter==='partially returned' ? 'selected' : '' %>>Partially
                Returned</option>
              <option value="return requested" <%=statusFilter==='return requested' ? 'selected' : '' %>>Return
                Requested</option>
              <option value="return approved" <%=statusFilter==='return approved' ? 'selected' : '' %>>Return Approved
              </option>
              <option value="return rejected" <%=statusFilter==='return rejected' ? 'selected' : '' %>>Return Rejected
              </option>
            </select>
          </div>
          <div class="col-md-2">
            <select id="sortSelect" class="form-select" onchange="applyFilters()">
              <option value="date_desc" <%=sortOption==='date_desc' ? 'selected' : '' %>>Date: Newest first</option>
              <option value="date_asc" <%=sortOption==='date_asc' ? 'selected' : '' %>>Date: Oldest first</option>
              <option value="amount_desc" <%=sortOption==='amount_desc' ? 'selected' : '' %>>Amount: High → Low</option>
              <option value="amount_asc" <%=sortOption==='amount_asc' ? 'selected' : '' %>>Amount: Low → High</option>
            </select>
          </div>
          <div class="col-md-2">
            <button class="btn btn-outline-secondary w-100" onclick="clearFilters()">Clear</button>
          </div>
        </div>

        <!-- Orders Table -->
        <div class="table-responsive">
          <table class="table align-middle admin-table" id="ordersTable">
            <thead class="table-light">
              <tr>
                <th>Order ID</th>
                <th>Order Date</th>
                <th>User</th>
                <th>Payment Method</th>
                <th>Payment</th>
                <th>Total (₹)</th>
                <th>Status</th>
                <th>Return</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="ordersTbody">
              <% if(noResults) { %>
                <tr>
                  <td colspan="9" class="text-center text-muted">No orders found</td>
                </tr>
                <% } else { %>
                  <% order.forEach(function(order) { %>
                    <tr>
                      <td>
                        <%= order.orderId %>
                      </td>
                      <td>
                        <%= order.createdAt.toLocaleDateString("en-IN") %>
                      </td>
                      <td>
                        <div>
                          <%= order.user ? order.user.name : "Unknown User" %>
                        </div>
                        <small class="text-muted">
                          <%= order.user ? order.user.email : "" %>
                        </small>
                      </td>
                      <td>
                        <%= order.paymentMethod %>
                      </td>
                      <td>
                        <% if (order.paymentStatus==='Failed' ) { %>
                          <span class="badge bg-danger">Failed</span>
                          <% } else if (order.paymentStatus==='Paid' ) { %>
                            <span class="badge bg-success">Paid</span>
                            <% } else if (order.paymentStatus==='Refunded' ) { %>
                              <span class="badge bg-info">Refunded</span>
                              <% } else if (order.paymentStatus==='Partially Refunded' ) { %>
                                <span class="badge bg-warning text-dark">Partially Refunded</span>
                                <% } else { %>
                                  <span class="badge bg-warning">Pending</span>
                                  <% } %>
                      </td>
                      <td>₹<%= order.finalAmount %>
                      </td>
                      <td>
                        <select name="status" class="form-select form-select-sm" data-order-id="<%= order._id %>"
                          <%=(order.paymentStatus==='Failed' || order.status==='Return Approved' ||
                          order.status==='Return Rejected' || order.status==='Partially Returned' ) ? 'disabled' : ''
                          %>>
                          <option value="pending" <%=order.status==="Pending" ? "selected" : "" %>>Pending</option>
                          <option value="shipped" <%=order.status==="Shipped" ? "selected" : "" %>>Shipped</option>
                          <option value="out for delivery" <%=order.status==="Out for Delivery" ? "selected" : "" %>>Out
                            for Delivery</option>
                          <option value="delivered" <%=order.status==="Delivered" ? "selected" : "" %>>Delivered
                          </option>
                          <option value="cancelled" <%=order.status==="Cancelled" ? "selected" : "" %>>Cancelled
                          </option>
                        </select>
                      </td>
                      <td>
                        <% 
                        // Check if there are any return requested items 
                        const hasReturnRequested=order.orderItems.some(item=> item.itemStatus === 'Return Requested');
                        // Check if there are any rejected items
                        const hasRejectedItems = order.orderItems.some(item => item.itemStatus === 'Return Rejected');
                        // Check if there are any approved items
                        const hasApprovedItems = order.orderItems.some(item => item.itemStatus === 'Return Approved');
                        %>

                          <!-- Case 1: There are pending return requests -->
                          <% if (hasReturnRequested) { %>
                            <span class="badge bg-warning text-dark">Requested</span>

                            <!-- Case 2: Some items were rejected (and no pending requests) -->
                            <% } else if (hasRejectedItems && !hasApprovedItems) { %>
                              <span class="badge bg-danger">Rejected</span>

                              <!-- Case 3: Some items were approved (and no pending requests) -->
                              <% } else if (hasApprovedItems && !hasRejectedItems && !hasReturnRequested) { %>
                                <span class="badge bg-success">Approved</span>

                                <!-- Case 4: Mixed approved and rejected (no pending) -->
                                <% } else if (hasApprovedItems && hasRejectedItems) { %>
                                  <span class="badge bg-info">Partially Processed</span>

                                  <!-- Case 5: Order status shows partially returned but no return activity -->
                                  <% } else if (order.status==='Partially Returned' ) { %>
                                    <span class="badge bg-info">Partially Returned</span>

                                    <!-- Default: No return activity -->
                                    <% } else { %>
                                      <span class="text-muted">—</span>
                                      <% } %>
                      </td>
                      <td>
                        <div class="d-flex gap-1 flex-wrap">
                          <!-- View button always visible -->
                          <a href="#" class="btn btn-sm btn-outline-primary view-order"
                            data-order-id="<%= order._id %>">View</a>

                          <% if (order.returnRequested && !order.returnVerified) { %>
                            <% const returnItemCount=order.orderItems.filter(item=> item.itemStatus === 'Return Requested').length; %>

                              <!-- OPTION 1: Show single "Verify Return" button that handles all items -->
                              <button type="button" class="btn btn-sm btn-outline-warning verify-return-btn"
                                data-order-id="<%= order._id %>">
                                Verify Return (<%= returnItemCount %> item<%= returnItemCount > 1 ? 's' : '' %>)
                              </button>

                              <% } %>

                                <!-- If no return requests, show nothing extra -->
                        </div>
                      </td>
                    </tr>
                    <% }) %>
                      <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <!-- View Order Modal -->
  <div class="modal fade" id="viewOrderModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Order Details</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <div id="orderDetailsContainer"></div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Return Verify Modal -->
  <div class="modal fade" id="returnVerifyModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Verify Return Request</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <div id="returnVerifyBody"></div>
        </div>
        <div class="modal-footer">
          <button id="rejectReturnBtn" type="button" class="btn btn-outline-danger">Reject</button>
          <button id="acceptReturnBtn" type="button" class="btn btn-success">Accept & Refund to Wallet</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Pagination -->
  <div class="container mt-3 pagination-container">
    <nav aria-label="Page Navigation">
      <ul class="pagination pagination-custom justify-content-center mb-20">
        <% for(let i=1; i <=totalPages; i++) { %>
          <li class="page-item <%=(i === currentPage) ? 'active' : '' %>">
            <a class="page-link" href="?page=<%= i %><%= queryString%>">
              <%= i %>
            </a>
          </li>
          <% } %>
      </ul>
    </nav>
  </div>

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <script>
    // Status update
    document.querySelectorAll('select[name="status"]').forEach(select => {
      select.addEventListener('change', async function () {
        const orderId = this.dataset.orderId;
        const status = this.value;

        try {
          const res = await fetch(`/admin/updateStatus/${orderId}`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ status })
          });

          const data = await res.json();

          if (data.success) {
            Swal.fire('Success', `Status updated to ${data.status}`, 'success').then(() => {
              location.reload();
            });
          } else {
            Swal.fire('Error', data.message || 'Failed to update status', 'error');
          }
        } catch (error) {
          console.error(error);
          Swal.fire('Error', 'Something went wrong.', 'error');
        }
      });
    });

    // View order details
    document.querySelectorAll('.view-order').forEach(btn => {
      btn.addEventListener('click', async function (e) {
        e.preventDefault();

        const orderId = this.dataset.orderId;
        const container = document.getElementById('orderDetailsContainer');

        try {
          const res = await fetch(`/admin/details/${orderId}`);
          const order = await res.json();

          // Check if any item has offer discount
          const hasOfferDiscount = order.orderItems.some(item =>
            item.finalPrice && (item.price - item.finalPrice) > 0
          );

          // Check if coupon discount is applied
          const hasCouponDiscount = order.discountAmount && order.discountAmount > 0;

          let html = `
          <h6>Order Information</h6>
          <ul class="list-group mb-3">
            <li class="list-group-item"><strong>Order ID:</strong> ${order.orderId}</li>
            <li class="list-group-item"><strong>Order Date:</strong> ${new Date(order.createdAt).toLocaleDateString("en-IN")}</li>
            <li class="list-group-item"><strong>Status:</strong> ${order.status}</li>
            <li class="list-group-item"><strong>Payment Method:</strong> ${order.paymentMethod}</li>
            <li class="list-group-item"><strong>Payment Status:</strong> ${order.paymentStatus}</li>
          </ul>

          <h6>Customer Details</h6>
          <ul class="list-group mb-3">
            <li class="list-group-item"><strong>Name:</strong> ${order.user?.name || "Unknown"}</li>
            <li class="list-group-item"><strong>Email:</strong> ${order.user?.email || "-"}</li>
            <li class="list-group-item"><strong>Address:</strong> ${order.selectedAddress?.fullAddress || "-"}</li>
          </ul>

          <h6>Products</h6>
          <table class="table table-sm table-bordered">
            <thead>
              <tr>
                <th>Product Name</th>
                <th>Price (₹)</th>
                <th>Qty</th>
                <th>Status</th>
                <th>Total (₹)</th>
                ${hasOfferDiscount ? '<th>Offer Discount (₹)</th>' : ''}
                ${hasCouponDiscount ? '<th>Coupon Discount (₹)</th>' : ''}
              </tr>
            </thead>
            <tbody>
              ${order.orderItems.map((item, index) => {
            const offerDiscount = item.finalPrice ? (item.price - item.finalPrice) * item.quantity : 0;
            const couponDiscount = index === 0 ? order.discountAmount || 0 : 0;

            let statusBadge = '';
            if (item.itemStatus === 'Return Requested') {
              statusBadge = '<span class="badge bg-warning">Return Requested</span>';
            } else if (item.itemStatus === 'Return Approved') {
              statusBadge = '<span class="badge bg-success">Return Approved</span>';
            } else if (item.itemStatus === 'Return Rejected') {
              statusBadge = '<span class="badge bg-danger">Return Rejected</span>';
            } else {
              statusBadge = item.itemStatus;
            }

            return `
                  <tr>
                    <td>${item.product?.productName || "Deleted Product"}</td>
                    <td>${item.price}</td>
                    <td>${item.quantity}</td>
                    <td>${statusBadge}</td>
                    <td>${item.price * item.quantity}</td>
                    ${hasOfferDiscount ? `<td>${offerDiscount > 0 ? `-₹${offerDiscount}` : '—'}</td>` : ''}
                    ${hasCouponDiscount ? `<td>${couponDiscount > 0 ? `-₹${couponDiscount}` : '—'}</td>` : ''}
                  </tr>
                `;
          }).join('')}
            </tbody>
          </table>

          <div class="text-end mt-2">
            <strong>Final Amount: ₹${order.finalAmount}</strong>
          </div>
        `;

          container.innerHTML = html;

          const viewOrderModal = new bootstrap.Modal(document.getElementById('viewOrderModal'));
          viewOrderModal.show();

        } catch (err) {
          console.error(err);
          container.innerHTML = '<p class="text-danger">Failed to load order details.</p>';
        }
      });
    });

    // Verify return buttons (order level)
    document.querySelectorAll('.verify-return-btn').forEach(btn => {
      btn.addEventListener('click', async function () {
        const orderId = this.dataset.orderId;
        const container = document.getElementById('returnVerifyBody');

        try {
          const res = await fetch(`/admin/details/${orderId}`);
          const order = await res.json();

          const returnItems = order.orderItems.filter(
            item => item.itemStatus === 'Return Requested'
          );

          const refundAmount = returnItems.reduce((sum, item) => {
            return sum + (item.finalPrice * item.quantity);
          }, 0);

          const getReturnReason = (item) => {
            if (item.itemReturnReason) return item.itemReturnReason;
            if (order.returnReason) return order.returnReason;
            return "No reason provided";
          };

          let html = `
          <p>Order <strong>${order.orderId}</strong> requested a return.</p>
          <p>User: ${order.user?.name || "Unknown"} (${order.user?.email || ""})</p>
          <h6>Products to Return</h6>
          <ul>
            ${returnItems.map(item => `
              <li>
                <strong>${item.product?.productName || "Deleted Product"}</strong>
                <br>
                ₹${item.finalPrice} × ${item.quantity} = ₹${item.finalPrice * item.quantity}
                <br>
                <small class="text-muted">
                  <span class="fw-bold">Reason:</span> ${getReturnReason(item)}
                </small>
                ${item.itemReturnDate ? `
                  <br>
                  <small class="text-muted">
                    Requested on: ${new Date(item.itemReturnDate).toLocaleDateString("en-IN")}
                  </small>
                ` : ''}
              </li>
            `).join('')}
          </ul>
          <hr>
          <p class="fw-bold mb-0">Total Refund Amount: ₹${refundAmount}</p>
          <p class="text-muted small">Amount will be credited to user's wallet</p>
        `;

          container.innerHTML = html;

          const returnVerifyModal = new bootstrap.Modal(document.getElementById('returnVerifyModal'));
          returnVerifyModal.show();

          document.getElementById('acceptReturnBtn').onclick = async function () {
            try {
              const res = await fetch(`/admin/acceptReturn/${orderId}`, { method: 'POST' });
              const data = await res.json();
              if (data.success) {
                returnVerifyModal.hide();
                Swal.fire('Success', 'Return accepted and refunded', 'success').then(() => { location.reload(); });
              } else {
                Swal.fire('Error', data.message || 'Something went wrong', 'error');
              }
            } catch (err) {
              console.error(err);
              Swal.fire('Error', 'Something went wrong', 'error');
            }
          };

          document.getElementById('rejectReturnBtn').onclick = async function () {
            try {
              const res = await fetch(`/admin/rejectReturn/${orderId}`, { method: 'POST' });
              const data = await res.json();
              if (data.success) {
                returnVerifyModal.hide();
                Swal.fire('Success', 'Return request rejected', 'success').then(() => { location.reload(); });
              } else {
                Swal.fire('Error', data.message || 'Something went wrong', 'error');
              }
            } catch (err) {
              console.error(err);
              Swal.fire('Error', 'Something went wrong', 'error');
            }
          };

        } catch (err) {
          console.error(err);
          container.innerHTML = '<p class="text-danger">Failed to load return details.</p>';
        }
      });
    });

    // Item-level verify buttons - Add this new event listener
    document.querySelectorAll('.verify-item-return').forEach(btn => {
      btn.addEventListener('click', async function (e) {
        e.preventDefault();
        const orderId = this.dataset.orderId;
        const itemId = this.dataset.itemId;

        const result = await Swal.fire({
          title: 'Verify Item Return',
          text: 'Are you sure you want to approve this item return?',
          icon: 'question',
          showCancelButton: true,
          confirmButtonColor: '#28a745',
          cancelButtonColor: '#d33',
          confirmButtonText: 'Yes, approve & refund'
        });

        if (result.isConfirmed) {
          try {
            const res = await fetch(`/admin/acceptItemReturn/${orderId}/${itemId}`, {
              method: 'POST'
            });
            const data = await res.json();

            if (data.success) {
              Swal.fire('Success', data.message, 'success').then(() => {
                location.reload();
              });
            } else {
              Swal.fire('Error', data.message || 'Something went wrong', 'error');
            }
          } catch (err) {
            console.error(err);
            Swal.fire('Error', 'Something went wrong', 'error');
          }
        }
      });
    });

    // Search and filters
    document.getElementById('searchInput').addEventListener('keypress', function (e) {
      if (e.key === 'Enter') {
        e.preventDefault();
        applyFilters();
      }
    });

    function applyFilters() {
      const search = document.getElementById('searchInput').value.trim();
      const status = document.getElementById('statusFilter').value;
      const sort = document.getElementById('sortSelect').value;

      let query = [];
      if (search) query.push(`search=${encodeURIComponent(search)}`);
      if (status) query.push(`status=${encodeURIComponent(status)}`);
      if (sort) query.push(`sort=${encodeURIComponent(sort)}`);

      window.location.href = `/admin/orders?${query.join('&')}`;
    }

    function clearFilters() {
      document.getElementById('searchInput').value = '';
      document.getElementById('statusFilter').value = '';
      document.getElementById('sortSelect').value = 'date_desc';
      window.location.href = '/admin/orders';
    }
  </script>

  <%-include("../../views/partials/admin/footer")%>