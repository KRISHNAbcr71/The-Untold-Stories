<%-include("../../views/partials/admin/header")%>

  <div class="container mt-5">
    <div class="card shadow-sm">
      <div class="card-header bg-dark text-white">
        <h4 class="mb-0">Add Offer</h4>
      </div>

      <div class="card-body">
        <form method="POST" action="/admin/addOffer" id="offerForm" onsubmit="return handleFormSubmit(event)">

          <!-- Offer Name -->
          <div class="mb-3">
            <label class="form-label">Offer Name</label>
            <input type="text" class="form-control" name="name" id="offerName" placeholder="e.g. New Year Offer">
          </div>

          <!-- Discount Value -->
          <div class="mb-3">
            <label class="form-label">Discount Value</label>
            <input type="number" class="form-control" name="discountValue" id="discountValue"
              placeholder="Enter discount (e.g. 10%)">
          </div>

          <!-- Applies To -->
          <div class="mb-3">
            <label class="form-label">Applies To</label>
            <div>
              <div class="form-check form-check-inline">
                <input class="form-check-input" type="radio" name="appliesTo" value="product" checked>
                <label class="form-check-label">Product</label>
              </div>

              <div class="form-check form-check-inline">
                <input class="form-check-input" type="radio" name="appliesTo" value="category">
                <label class="form-check-label">Category</label>
              </div>
            </div>
          </div>

          <!-- Select Targets -->
          <div class="mb-3">
            <label class="form-label">Select Targets</label>

            <!-- Products -->

            <div id="productTargets">
              <% if (products.length===0) { %>
                <p class="text-muted">No products available</p>
                <% } %>
                  <%products.forEach(product=> {%>
                    <div class="form-check">
                      <input class="form-check-input" type="checkbox" name="targetIds[]" value="<%= product._id %>">
                      <label class="form-check-label">
                        <%= product.productName%>
                      </label>
                    </div>
                    <%})%>
            </div>

            <!-- Categories -->
            <div id="categoryTargets" class="d-none">
              <% if (categories.length===0) { %>
                <p class="text-muted">No products available</p>
                <% } %>
                  <%categories.forEach(category=> {%>
                    <div class="form-check">
                      <input class="form-check-input" type="checkbox" name="targetIds[]" value="<%= category._id %>">
                      <label class="form-check-label">
                        <%= category.name%>
                      </label>
                    </div>
                    <%})%>
            </div>
          </div>

          <!-- Dates -->
          <div class="row mb-3">
            <div class="col-md-6">
              <label class="form-label">Start Date</label>
              <input type="date" class="form-control" name="startDate" id="startDate">
            </div>

            <div class="col-md-6">
              <label class="form-label">End Date</label>
              <input type="date" class="form-control" name="endDate" id="endDate">
            </div>
          </div>

          <!-- Buttons -->
          <div class="d-flex justify-content-end gap-2">
            <a href="/admin/offers" class="btn btn-secondary">Cancel</a>
            <button type="submit" class="btn btn-primary">Save Offer</button>
          </div>

        </form>
      </div>
    </div>
  </div>


  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>


  <script>
    const appliesToRadios = document.querySelectorAll('input[name="appliesTo"]');
    const productTargets = document.getElementById('productTargets');
    const categoryTargets = document.getElementById('categoryTargets');

    appliesToRadios.forEach(radio => {
      radio.addEventListener('change', () => {
        if (radio.value === 'product' && radio.checked) {
          productTargets.classList.remove('d-none');
          categoryTargets.classList.add('d-none');
        }
        if (radio.value === 'category' && radio.checked) {
          categoryTargets.classList.remove('d-none');
          productTargets.classList.add('d-none');
        }
      });
    });



    // Set default start date as today
    window.onload = () => {
      const today = new Date().toISOString().split('T')[0];
      document.getElementById('startDate').min = today;
      document.getElementById('startDate').value = today;
    };

    // Form submit handler
    async function handleFormSubmit(event) {
      event.preventDefault();

      const name = document.getElementById('offerName').value.trim();
      const discountValue = Number(document.getElementById('discountValue').value);
      const startDate = document.getElementById('startDate').value;
      const endDate = document.getElementById('endDate').value;
      const appliesTo = document.querySelector('input[name="appliesTo"]:checked').value;

      const targetIds = Array.from(
        document.querySelectorAll(
          appliesTo === 'product'
            ? '#productTargets input[type="checkbox"]:checked'
            : '#categoryTargets input[type="checkbox"]:checked'
        )
      ).map(cb => cb.value);

      // Basic validation

      if (!name || !discountValue || !startDate || !endDate || !appliesTo) {
        return Swal.fire("Error", "All fields are required", "error");
      }

      if (discountValue <= 0) {
        return Swal.fire('Error', 'Enter a valid discount value', 'error');
      }

      if (startDate === endDate) {
        return Swal.fire('Error', 'Start date and end date cannot be the same', 'error');
      }

      if (endDate < startDate) {
        return Swal.fire('Error', 'Invalid date range', 'error');
      }

      if (targetIds.length === 0) {
        Swal.fire('Error', 'Select at least one product or category', 'error');
        return;
      }

      try {
        const response = await fetch('/admin/addOffer', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            name,
            discountValue,
            appliesTo,
            targetIds,
            startDate,
            endDate
          })
        });

        const data = await response.json();

        if (!response.ok) throw new Error(data.message);

        Swal.fire({
          icon: 'success',
          title: 'Offer Added',
          text: 'The offer has been successfully added'
        }).then(() => {
          window.location.href = '/admin/offer';
        });

      } catch (error) {
        console.log(error)
        Swal.fire('Error', error.message || 'Failed to add offer', 'error');
      }
    }

  </script>