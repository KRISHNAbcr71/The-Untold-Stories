<%-include("../../views/partials/admin/header")%>
<link rel="stylesheet" href="/css/add-offer.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

  <!-- Add Offer Page with Custom Design -->
<div class="add-offer-wrapper">
    <!-- Page Header -->
    <div class="page-header">
        <div class="header-content">
            <div class="header-icon">
                <i class="bi bi-tags-fill" style="font-size: 1.5rem;"></i>
            </div>
            <div>
                <h1 class="page-title">Add New Offer</h1>
                <p class="page-subtitle">Create a new discount offer for products or categories</p>
            </div>
        </div>
        <a href="/admin/offer" class="back-link">
            <i class="bi bi-arrow-left"></i>
            <span>Back to Offers</span>
        </a>
    </div>

    <!-- Main Form Card -->
    <div class="form-card">
        <div class="card-pattern"></div>
        <div class="form-fields">
            <form method="POST" action="/admin/addOffer" id="offerForm" onsubmit="return handleFormSubmit(event)">
                <!-- Form Grid Layout -->
                <div class="form-grid">
                    <!-- Left Column -->
                    <div>
                        <!-- Offer Name -->
                        <div class="field-group">
                            <label for="offerName" class="field-label">
                                <i class="bi bi-tag-fill"></i>
                                Offer Name
                            </label>
                            <div class="input-wrapper">
                                <input type="text" class="form-control" id="offerName" name="name" 
                                       placeholder="e.g. New Year Offer">
                                <div class="input-border"></div>
                            </div>
                        </div>

                        <!-- Discount Value -->
                        <div class="field-group">
                            <label for="discountValue" class="field-label">
                                <i class="bi bi-percent"></i>
                                Discount Value (%)
                            </label>
                            <div class="input-wrapper">
                                <input type="number" class="form-control" id="discountValue" name="discountValue" 
                                       placeholder="Enter discount (e.g. 10)">
                                <div class="input-border"></div>
                            </div>
                        </div>

                        <!-- Applies To -->
                        <div class="field-group">
                            <label class="field-label">
                                <i class="bi bi-grid-3x3-gap-fill"></i>
                                Applies To
                            </label>
                            <div class="radio-group">
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="appliesTo" value="product" id="radioProduct" checked>
                                    <label class="form-check-label" for="radioProduct">
                                        <i class="bi bi-box-seam"></i> Product
                                    </label>
                                </div>
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="appliesTo" value="category" id="radioCategory">
                                    <label class="form-check-label" for="radioCategory">
                                        <i class="bi bi-folder"></i> Category
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Right Column -->
                    <div>
                        <!-- Start Date -->
                        <div class="field-group">
                            <label for="startDate" class="field-label">
                                <i class="bi bi-calendar-check"></i>
                                Start Date
                            </label>
                            <div class="input-wrapper">
                                <input type="date" class="form-control" name="startDate" id="startDate">
                                <div class="input-border"></div>
                            </div>
                        </div>

                        <!-- End Date -->
                        <div class="field-group">
                            <label for="endDate" class="field-label">
                                <i class="bi bi-calendar-x"></i>
                                End Date
                            </label>
                            <div class="input-wrapper">
                                <input type="date" class="form-control" name="endDate" id="endDate">
                                <div class="input-border"></div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Select Targets Section -->
                <div class="targets-section">
                    <div class="section-title">
                        <i class="bi bi-check2-square"></i>
                        <span>Select Targets</span>
                    </div>

                    <!-- Products Container -->
                    <div id="productTargets" class="targets-container">
                        <% if (products.length === 0) { %>
                            <p class="text-muted">No products available</p>
                        <% } else { %>
                            <div class="targets-grid">
                                <% products.forEach(product => { %>
                                    <div class="target-item">
                                        <input class="form-check-input" type="checkbox" name="targetIds[]" 
                                               value="<%= product._id %>" id="product_<%= product._id %>">
                                        <label class="form-check-label" for="product_<%= product._id %>">
                                            <i class="bi bi-box"></i>
                                            <%= product.productName %>
                                        </label>
                                    </div>
                                <% }) %>
                            </div>
                        <% } %>
                    </div>

                    <!-- Categories Container -->
                    <div id="categoryTargets" class="targets-container d-none">
                        <% if (categories.length === 0) { %>
                            <p class="text-muted">No categories available</p>
                        <% } else { %>
                            <div class="targets-grid">
                                <% categories.forEach(category => { %>
                                    <div class="target-item">
                                        <input class="form-check-input" type="checkbox" name="targetIds[]" 
                                               value="<%= category._id %>" id="category_<%= category._id %>">
                                        <label class="form-check-label" for="category_<%= category._id %>">
                                            <i class="bi bi-folder"></i>
                                            <%= category.name %>
                                        </label>
                                    </div>
                                <% }) %>
                            </div>
                        <% } %>
                    </div>
                </div>

                <!-- Form Footer -->
                <div class="form-footer">
                    <div class="footer-decoration"></div>
                    <div class="button-group">
                        <a href="/admin/offer" class="btn btn-outline">
                            <i class="bi bi-x-circle"></i>
                            <span>Cancel</span>
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle"></i>
                            <span>Save Offer</span>
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Quick Tips -->
    <div class="tips-grid">
        <div class="tip-card">
            <div class="tip-icon">
                <i class="bi bi-lightbulb-fill"></i>
            </div>
            <div>
                <h4>Valid Discount</h4>
                <p>Enter a positive discount value between 1-100%</p>
            </div>
        </div>
        <div class="tip-card">
            <div class="tip-icon">
                <i class="bi bi-calendar-range"></i>
            </div>
            <div>
                <h4>Date Range</h4>
                <p>End date must be after start date</p>
            </div>
        </div>
        <div class="tip-card">
            <div class="tip-icon">
                <i class="bi bi-check2-all"></i>
            </div>
            <div>
                <h4>Select Targets</h4>
                <p>Choose at least one product or category</p>
            </div>
        </div>
    </div>
</div>


  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>


  <script>
    const appliesToRadios = document.querySelectorAll('input[name="appliesTo"]');
    const productTargets = document.getElementById('productTargets');
    const categoryTargets = document.getElementById('categoryTargets');

    appliesToRadios.forEach(radio => {
        radio.addEventListener('change', () => {
            if (radio.value === 'product' && radio.checked) {
                productTargets.classList.remove('d-none');
                categoryTargets.classList.add('d-none');
            }
            if (radio.value === 'category' && radio.checked) {
                categoryTargets.classList.remove('d-none');
                productTargets.classList.add('d-none');
            }
        });
    });

    // Set default start date as today
    window.onload = () => {
        const today = new Date().toISOString().split('T')[0];
        document.getElementById('startDate').min = today;
        document.getElementById('startDate').value = today;
    };

    // Form submit handler
    async function handleFormSubmit(event) {
        event.preventDefault();

        const name = document.getElementById('offerName').value.trim();
        const discountValue = Number(document.getElementById('discountValue').value);
        const startDate = document.getElementById('startDate').value;
        const endDate = document.getElementById('endDate').value;
        const appliesTo = document.querySelector('input[name="appliesTo"]:checked').value;

        const targetIds = Array.from(
            document.querySelectorAll(
                appliesTo === 'product'
                    ? '#productTargets input[type="checkbox"]:checked'
                    : '#categoryTargets input[type="checkbox"]:checked'
            )
        ).map(cb => cb.value);

        if (!name || !discountValue || !startDate || !endDate || !appliesTo) {
            return Swal.fire({
                icon: 'error',
                title: 'Error',
                text: 'All fields are required',
                confirmButtonColor: '#d4a373'
            });
        }

        if (discountValue <= 0 || discountValue > 100) {
            return Swal.fire({
                icon: 'error',
                title: 'Error',
                text: 'Enter a valid discount value between 1 and 100',
                confirmButtonColor: '#d4a373'
            });
        }

        if (startDate === endDate) {
            return Swal.fire({
                icon: 'error',
                title: 'Error',
                text: 'Start date and end date cannot be the same',
                confirmButtonColor: '#d4a373'
            });
        }

        if (endDate < startDate) {
            return Swal.fire({
                icon: 'error',
                title: 'Error',
                text: 'End date must be after start date',
                confirmButtonColor: '#d4a373'
            });
        }

        if (targetIds.length === 0) {
            return Swal.fire({
                icon: 'error',
                title: 'Error',
                text: 'Select at least one product or category',
                confirmButtonColor: '#d4a373'
            });
        }

        try {
            const response = await fetch('/admin/addOffer', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    name,
                    discountValue,
                    appliesTo,
                    targetIds,
                    startDate,
                    endDate
                })
            });

            const data = await response.json();

            if (!response.ok) throw new Error(data.message);

            Swal.fire({
                icon: 'success',
                title: 'Offer Added',
                text: 'The offer has been successfully added',
                confirmButtonColor: '#d4a373'
            }).then(() => {
                window.location.href = '/admin/offer';
            });

        } catch (error) {
            console.log(error);
            Swal.fire({
                icon: 'error',
                title: 'Error',
                text: error.message || 'Failed to add offer',
                confirmButtonColor: '#d4a373'
            });
        }
    }
</script>


<%-include("../../views/partials/admin/footer")%>