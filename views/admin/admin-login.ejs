<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <title>Admin Login</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
  :root {
  --primary: #d4a373;
  --primary-hover: #c08c5a;

  --bg-body: #1f1a14; /* keep dark background */
  --bg-surface: #ffffff;

  --text-main: #1e293b;
  --text-muted: #6b7280;

  --border: #e5e7eb;

  --error-bg: #fef2f2;
  --error-text: #dc2626;

  --grid-color: rgba(212, 163, 115, 0.08);
}

  body {
    margin: 0;
    height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    font-family: 'Inter', sans-serif;
    
    /* Layer 1: The Dark Base */
    background-color: var(--bg-body);
    
    /* Layer 2: The Grid Pattern */
    background-image: 
      linear-gradient(var(--grid-color) 1px, transparent 1px),
      linear-gradient(90deg, var(--grid-color) 1px, transparent 1px);
    background-size: 40px 40px;
    
    /* Layer 3: A subtle glow in the center to make the login box "pop" */
    background-attachment: fixed;
    position: relative;
    overflow: hidden;
  }

  /* Optional: Decorative "Glass" Blur Circles in the background */
  body::before {
    content: "";
    position: absolute;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(37, 99, 235, 0.1) 0%, transparent 70%);
    top: -100px;
    right: -100px;
    z-index: -1;
  }

  body::after {
    content: "";
    position: absolute;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.05) 0%, transparent 70%);
    bottom: -150px;
    left: -150px;
    z-index: -1;
  }

  /* .login-box {
    background: #ffffff;
    padding: 40px;
    border-radius: 16px;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    width: 100%;
    max-width: 400px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    z-index: 1;
  } */
   .login-box {
  background: rgba(255, 255, 255, 0.96);
  padding: 42px;
  border-radius: 18px;
  box-shadow: 
    0 25px 50px -12px rgba(0, 0, 0, 0.6),
    0 0 0 1px rgba(212, 163, 115, 0.15);
  width: 100%;
  max-width: 400px;
  z-index: 1;
}

  /* h2 {
    text-align: center;
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 8px;
    letter-spacing: -0.025em;
  } */
   h2 {
  text-align: center;
  font-size: 1.6rem;
  font-weight: 700;
  margin-bottom: 18px;
  letter-spacing: -0.03em;
  color: #1e293b;
}

h2::after {
  content: "";
  display: block;
  width: 40px;
  height: 3px;
  background: var(--primary);
  margin: 10px auto 0;
  border-radius: 2px;
}



  .form-group {
    margin-bottom: 20px;
  }

  label {
    display: block;
    font-size: 0.875rem;
    font-weight: 500;
    margin-bottom: 6px;
    color: var(--text-main);
  }

  .input-container {
    position: relative;
    display: flex;
    align-items: center;
  }

  input[type="email"],
  input[type="password"],
  input[type="text"] {
    width: 100%;
    height: 44px;
    padding: 10px 14px;
    border: 1px solid var(--border);
    border-radius: 8px;
    font-size: 0.95rem;
    transition: all 0.2s ease;
    background: #fff;
    box-sizing: border-box;
  }

  input:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 0 3px rgba(212, 163, 115, 0.25);
  }

  /* .eye-toggle {
    position: absolute;
    right: 12px;
    cursor: pointer;
    font-size: 18px;
    filter: grayscale(1);
    opacity: 0.6;
    transition: opacity 0.2s;
  }

  .eye-toggle:hover {
    opacity: 1;
  } */
   .eye-toggle {
  position: absolute;
  right: 12px;
  cursor: pointer;
  font-size: 18px;
  color: var(--text-muted);
  transition: color 0.2s, opacity 0.2s;
}

.eye-toggle:hover {
  color: var(--primary);
  opacity: 1;
}


  .error {
    color: var(--error-text);
    font-size: 0.8rem;
    margin-top: 6px;
    font-weight: 500;
  }

  /* button {
    width: 100%;
    padding: 12px;
    background-color: var(--primary);
    color: white;
    border: none;
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.2s;
    margin-top: 10px;
  }

  button:hover {
    background-color: var(--primary-hover);
  } */
   button {
  width: 100%;
  padding: 12px;
  background-color: var(--primary);
  color: #1e293b;
  border: none;
  border-radius: 10px;
  font-size: 0.95rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.25s ease;
  margin-top: 10px;
}

button:hover {
  background-color: var(--primary-hover);
  transform: translateY(-1px);
}


  /* Redesigned Server Error Message */
  /* .alert-danger {
    background-color: var(--error-bg);
    color: var(--error-text);
    border: 1px solid #fee2e2;
    font-size: 0.9rem;
    padding: 12px;
    border-radius: 8px;
    text-align: center;
    margin-bottom: 20px;
    font-weight: 500;
  } */
   .alert-danger {
  background-color: var(--error-bg);
  color: var(--error-text);
  border-left: 4px solid var(--primary);
  font-size: 0.9rem;
  padding: 12px;
  border-radius: 8px;
  text-align: center;
  margin-bottom: 20px;
  font-weight: 500;
}

</style>
</head>

<body>

  <div class="login-box">
    <h2>Admin Login</h2>
    <form id="adminLoginForm" action="/admin/login" method="POST" autocomplete="off" novalidate>

      <%if(message){%>
        <div id="error-message" class="alert alert-danger">
          <%=message%>
        </div>
        <%}%>

          <div class="form-group password-wrapper">
            <label for="adminEmail">Email Address</label>
            <div class="input-container">
              <input type="email" id="adminEmail" name="email" autocomplete="off">
            </div>
            <div class="error" id="emailError"></div>
          </div>

          <div class="form-group password-wrapper">
            <label for="adminPassword">Password</label>
            <div class="input-container">
              <input type="password" id="adminPassword" name="password" autocomplete="off">
              <span id="toggleIcon" class="eye-toggle">👁️</span>
            </div>
            <div class="error" id="passwordError"></div>
          </div>

          <button type="submit">Login</button>
    </form>
  </div>


  <script>

    document.addEventListener("DOMContentLoaded", function () {

      const form = document.getElementById("adminLoginForm");
      const email = document.getElementById("adminEmail");
      const password = document.getElementById("adminPassword");
      const emailError = document.getElementById("emailError");
      const passwordError = document.getElementById("passwordError");
      const toggleIcon = document.getElementById('toggleIcon')
      const errorMessage = document.getElementById('error-message')


      // Function to hide errors
      function hideError() {
        if (errorMessage)
          errorMessage.style.display = 'none'
      }
    

      email.addEventListener('input', hideError)
      password.addEventListener('input', hideError)

      email.addEventListener('input', () => {
        emailError.textContent = ''
      })

      password.addEventListener('input', () => {
        passwordError.textContent = ''
      })



      // Toggle password visibility
      toggleIcon.addEventListener('click', () => {
        if (password.value.trim() === '') {
          return
        }

        if (password.type === 'password') {
          password.type = 'text'
          toggleIcon.textContent = '🙈'
        } else {
          password.type = 'password'
          toggleIcon.textContent = '👁️'
        }
      })


      // Validate form on submit
      form.addEventListener("submit", function (e) {
        let valid = true;
        const emailPattern = /^[^@\s]+@[^@\s]+\.[^@\s]+$/;

        if (!emailPattern.test(email.value.trim())) {
          emailError.textContent = "Please enter a valid email address";
          valid = false;
        }

        if (password.value.trim().length < 8) {
          passwordError.textContent = "Password must be at least 8 characters";
          valid = false;
        }

        if (!valid) {
          e.preventDefault();
        }

      });
    });

  </script>
</body>
</html>